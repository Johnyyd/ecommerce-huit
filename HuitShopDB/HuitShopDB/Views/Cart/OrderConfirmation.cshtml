@model HuitShopDB.Models.DTOs.Order.OrderResponseDto
@{
    ViewBag.Title = "Đặt hàng thành công - HUIT Shop";
}
<style>
    .confirm-wrap { max-width: 780px; margin: 40px auto; padding: 0 20px 60px; text-align: center; }
    .success-icon { font-size: 5rem; margin-bottom: 20px; animation: bounceIn 0.8s ease; }
    @@keyframes bounceIn { 0%{transform:scale(0);opacity:0} 60%{transform:scale(1.15)} 100%{transform:scale(1);opacity:1} }
    .confirm-title { color: #0f172a; font-size: 2rem; font-weight: 800; margin-bottom: 8px; }
    .confirm-sub { color: #64748b; font-size: 0.95rem; margin-bottom: 30px; }
    .order-code-badge { display: inline-block; background: rgba(215,0,24,0.08); border: 1px solid rgba(215,0,24,0.2); color: #d70018; font-size: 1.1rem; font-weight: 700; padding: 10px 28px; border-radius: 50px; margin-bottom: 30px; }
    .confirm-card { background: #fff; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border-radius: 16px; padding: 30px; margin-bottom: 24px; text-align: left; }
    .confirm-card-title { color: #0f172a; font-size: 1.05rem; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
    .confirm-card-title i { color: #d70018; }
    .info-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px dashed #e2e8f0; font-size: 0.95rem; }
    .info-row:last-child { border-bottom: none; }
    .info-label { color: #64748b; }
    .info-val { color: #0f172a; font-weight: 600; }
    .item-row { display: flex; gap: 16px; align-items: center; padding: 16px 0; border-bottom: 1px dashed #e2e8f0; }
    .item-row:last-child { border-bottom: none; }
    .item-thumb { width: 64px; height: 64px; border-radius: 10px; object-fit: cover; background: #f8fafc; flex-shrink: 0; border: 1px solid #e2e8f0; }
    .item-details { flex: 1; }
    .item-name { color: #0f172a; font-size: 0.95rem; font-weight: 600; margin-bottom: 4px; }
    .item-sku { color: #64748b; font-size: 0.8rem; }
    .item-qty { color: #64748b; font-size: 0.85rem; margin-top: 4px; }
    .item-total { color: #d70018; font-weight: 700; font-size: 1rem; flex-shrink: 0; }
    .totals-section { background: #f8fafc; border-radius: 12px; padding: 20px; border: 1px solid #f1f5f9; }
    .totals-row { display: flex; justify-content: space-between; font-size: 0.95rem; color: #64748b; padding: 8px 0; }
    .totals-row.grand { font-size: 1.15rem; color: #0f172a; font-weight: 800; border-top: 2px solid #e2e8f0; margin-top: 10px; padding-top: 14px; }
    .totals-row.grand .tval { color: #d70018; }
    .payment-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(46,213,115,0.1); border: 1px solid #2ed573; border-radius: 8px; padding: 5px 12px; color: #10b981; font-weight: 600; font-size: 0.82rem; }
    .status-badge { display: inline-block; padding: 4px 14px; border-radius: 20px; font-size: 0.8rem; font-weight: 700; }
    .status-PENDING { background: rgba(255,193,7,0.15); color: #d97706; }
    .action-btns { display: flex; gap: 14px; justify-content: center; margin-top: 40px; flex-wrap: wrap; }
    .btn-primary-action { background: #d70018; color: #fff; padding: 13px 30px; border-radius: 12px; text-decoration: none; font-weight: 700; font-size: 0.95rem; border: none; box-shadow: 0 4px 10px rgba(215,0,24,0.25); transition: all 0.2s ease; }
    .btn-secondary-action { background: #fff; border: 1px solid #cbd5e1; color: #0f172a; padding: 13px 30px; border-radius: 12px; text-decoration: none; font-weight: 600; font-size: 0.95rem; transition: all 0.2s ease; }
    .btn-primary-action:hover { transform: translateY(-2px); box-shadow: 0 6px 15px rgba(215,0,24,0.35); color: #fff; text-decoration: none; }
    .btn-secondary-action:hover { border-color: #d70018; color: #d70018; text-decoration: none; background: #fffafb; }
    .timeline-mini { display: flex; gap: 0; margin-top: 10px; }
    .tl-step { flex: 1; text-align: center; position: relative; }
    .tl-step::before { content:''; position: absolute; top: 14px; left: 50%; right: -50%; height: 3px; background: #e2e8f0; z-index: 0; }
    .tl-step:last-child::before { display: none; }
    .tl-dot { width: 32px; height: 32px; border-radius: 50%; background: #e2e8f0; color: #64748b; margin: 0 auto 8px; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: bold; position: relative; z-index: 1; box-shadow: 0 0 0 4px #fff; }
    .tl-dot.active { background: #10b981; color: #fff; }
    .tl-label { color: #64748b; font-size: 0.75rem; font-weight: 500; }
    .tl-label.active { color: #10b981; font-weight: 700; }
</style>

<div class="confirm-wrap">
    <div class="success-icon">🎉</div>
    <h1 class="confirm-title">Đặt hàng thành công!</h1>
    <p class="confirm-sub">Cảm ơn bạn đã mua sắm tại HUIT Shop. Chúng tôi sẽ xử lý đơn hàng ngay!</p>

    <div class="order-code-badge">
        <i class="fas fa-receipt"></i> &nbsp; Mã đơn hàng: <strong>@Model.Code</strong>
    </div>

    <!-- Timeline trạng thái -->
    <div class="confirm-card" style="margin-bottom:24px;">
        <div class="confirm-card-title"><i class="fas fa-route"></i> Theo dõi trạng thái đơn hàng</div>
        <div class="timeline-mini">
            @{
                var steps = new string[][] {
                    new[]{ "PENDING",   "⏳", "Chờ xử lý" },
                    new[]{ "CONFIRMED", "✅", "Xác nhận"    },
                    new[]{ "SHIPPING",  "🚚", "Đang giao"    },
                    new[]{ "COMPLETED", "🏠", "Hoàn tất"    }
                };
                var stepOrder = new[] { "PENDING", "CONFIRMED", "SHIPPING", "COMPLETED" };
            }
            @foreach (var step in steps)
            {
                bool isPast = Array.IndexOf(stepOrder, Model.Status) >= Array.IndexOf(stepOrder, step[0]);
                <div class="tl-step">
                    <div class="tl-dot @(isPast ? "active" : "")">@(isPast ? "✓" : step[1])</div>
                    <div class="tl-label @(Model.Status == step[0] ? "active" : "")">@step[2]</div>
                </div>
            }
        </div>
    </div>

    <!-- Thông tin đơn hàng -->
    <div class="confirm-card">
        <div class="confirm-card-title"><i class="fas fa-info-circle"></i> Thông tin đơn hàng</div>
        <div class="info-row"><span class="info-label">Ngày đặt</span><span class="info-val">@Model.CreatedAt.AddHours(7).ToString("HH:mm - dd/MM/yyyy")</span></div>
        <div class="info-row"><span class="info-label">Phương thức TT</span><span class="info-val">@(Model.PaymentMethod == "COD" ? "💵 Thanh toán khi nhận hàng" : Model.PaymentMethod == "BANK_TRANSFER" ? "🏦 Chuyển khoản ngân hàng" : "💜 Ví MoMo")</span></div>
        <div class="info-row"><span class="info-label">Trạng thái thanh toán</span><span class="info-val"><span class="payment-badge"><i class="fas fa-circle" style="font-size:0.6rem;"></i> @(Model.PaymentStatus == "PAID" ? "Đã thanh toán" : "Chờ thanh toán")</span></span></div>
        @if (!string.IsNullOrEmpty(Model.FullAddress))
        {
            <div class="info-row"><span class="info-label">Giao đến</span><span class="info-val">@Model.RecipientName — @Model.FullAddress</span></div>
        }
        @if (!string.IsNullOrEmpty(Model.Note))
        {
            <div class="info-row"><span class="info-label">Ghi chú</span><span class="info-val">@Model.Note</span></div>
        }
    </div>

    <!-- Sản phẩm đã mua -->
    <div class="confirm-card">
        <div class="confirm-card-title"><i class="fas fa-shopping-bag"></i> Sản phẩm trong đơn hàng</div>
        @foreach (var item in Model.Items)
        {
            <div class="item-row">
                @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                {
                    <img class="item-thumb" src="@item.ThumbnailUrl" alt="@item.ProductName" />
                }
                else
                {
                    <div class="item-thumb" style="display:flex;align-items:center;justify-content:center;color:#555;"><i class="fas fa-image"></i></div>
                }
                <div class="item-details">
                    <div class="item-name">@item.ProductName</div>
                    <div class="item-sku">SKU: @item.Sku</div>
                    <div class="item-qty">x@item.Quantity &nbsp; @item.UnitPrice.ToString("N0")đ/cái</div>
                </div>
                <div class="item-total">@item.TotalPrice.ToString("N0")đ</div>
            </div>
        }
        <div class="totals-section" style="margin-top:16px;">
            <div class="totals-row"><span>Tạm tính</span><span class="tval">@Model.Subtotal.ToString("N0")đ</span></div>
            @if (Model.Discount > 0)
            {
                <div class="totals-row" style="color:#2ed573;"><span>Giảm giá voucher</span><span>-@Model.Discount.ToString("N0")đ</span></div>
            }
            <div class="totals-row"><span>Phí vận chuyển</span><span class="tval">@(Model.ShippingFee == 0 ? "Miễn phí" : Model.ShippingFee.ToString("N0") + "đ")</span></div>
            <div class="totals-row grand"><span>Tổng thanh toán</span><span class="tval">@Model.Total.ToString("N0")đ</span></div>
        </div>
    </div>

    <div class="action-btns">
        <a href="@Url.Action("Details", "Order", new { code = Model.Code })" class="btn-primary-action">
            <i class="fas fa-eye"></i> Xem chi tiết đơn hàng
        </a>
        <a href="@Url.Action("History", "Order")" class="btn-secondary-action">
            <i class="fas fa-list"></i> Lịch sử mua hàng
        </a>
        <a href="@Url.Action("Index", "Product")" class="btn-secondary-action">
            <i class="fas fa-shopping-bag"></i> Tiếp tục mua sắm
        </a>
    </div>
</div>
