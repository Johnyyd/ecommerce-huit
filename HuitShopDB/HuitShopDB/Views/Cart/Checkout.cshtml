@model HuitShopDB.Models.DTOs.Cart.CartDto
@{
    ViewBag.Title = "Thanh Toán - HUIT Shop";
    var addresses = ViewBag.Addresses as IEnumerable<HuitShopDB.Models.address> ?? new List<HuitShopDB.Models.address>();
    bool hasAddresses = addresses.Any();
    decimal shippingFee = ViewBag.ShippingFee != null ? (decimal)ViewBag.ShippingFee : 0m;
    string appliedVoucher = ViewBag.AppliedVoucherCode != null ? (string)ViewBag.AppliedVoucherCode : "";
    string userFullName = ViewBag.UserFullName != null ? (string)ViewBag.UserFullName : "";
    string userPhone = ViewBag.UserPhone != null ? (string)ViewBag.UserPhone : "";
}
<style>
    body { background: #0f0f17; }
    .checkout-wrap { max-width: 1100px; margin: 0 auto; padding: 30px 20px 60px; }
    .checkout-title { color: #fff; font-size: 1.8rem; font-weight: 700; margin-bottom: 8px; }
    .checkout-subtitle { color: #888; font-size: 0.95rem; margin-bottom: 36px; }
    .steps-bar { display: flex; align-items: center; gap: 0; margin-bottom: 40px; }
    .step { display: flex; align-items: center; gap: 10px; flex: 1; }
    .step-num { width: 32px; height: 32px; border-radius: 50%; background: #6c63ff; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 700; flex-shrink: 0; }
    .step-label { color: #fff; font-size: 0.85rem; font-weight: 600; }
    .step-divider { flex: 1; height: 2px; background: #2a2a3e; max-width: 60px; }
    .card-section { background: #1a1a2e; border: 1px solid #2a2a3e; border-radius: 16px; padding: 28px; margin-bottom: 24px; }
    .section-title { color: #fff; font-size: 1rem; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
    .section-title i { color: #6c63ff; }
    .form-label { color: #aaa; font-size: 0.82rem; margin-bottom: 6px; display: block; }
    .form-control-dark { background: #12122a; border: 1px solid #2a2a3e; color: #fff; border-radius: 10px; padding: 10px 14px; width: 100%; font-size: 0.9rem; transition: border-color 0.2s; box-sizing: border-box; }
    .form-control-dark:focus { outline: none; border-color: #6c63ff; background: #16163a; }
    .form-control-dark::placeholder { color: #555; }
    .payment-options { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
    .pay-card { background: #12122a; border: 2px solid #2a2a3e; border-radius: 14px; padding: 18px 16px; cursor: pointer; text-align: center; transition: all 0.25s; position: relative; }
    .pay-card:hover, .pay-card.selected { border-color: #6c63ff; background: rgba(108,99,255,0.08); }
    .pay-card input[type=radio] { position: absolute; opacity: 0; }
    .pay-card .pay-icon { font-size: 2rem; margin-bottom: 8px; display: block; }
    .pay-card .pay-name { color: #fff; font-size: 0.85rem; font-weight: 600; }
    .pay-card .pay-desc { color: #666; font-size: 0.75rem; margin-top: 4px; }
    .voucher-row { display: flex; gap: 10px; }
    .btn-apply { background: #6c63ff; color: #fff; border: none; border-radius: 10px; padding: 10px 20px; font-weight: 600; cursor: pointer; white-space: nowrap; font-size: 0.88rem; }
    .btn-apply:hover { background: #5a52e0; }
    .btn-apply.remove { background: #3a3a5e; }
    .voucher-success { background: rgba(46,213,115,0.1); border: 1px solid #2ed573; border-radius: 10px; padding: 10px 14px; color: #2ed573; font-size: 0.85rem; display: none; margin-top: 10px; }
    .voucher-error { background: rgba(255,71,87,0.1); border: 1px solid #ff4757; border-radius: 10px; padding: 10px 14px; color: #ff4757; font-size: 0.85rem; display: none; margin-top: 10px; }
    .order-summary { background: #1a1a2e; border: 1px solid #2a2a3e; border-radius: 16px; padding: 28px; position: sticky; top: 20px; }
    .summary-title { color: #fff; font-size: 1rem; font-weight: 700; margin-bottom: 20px; }
    .summary-item { display: flex; gap: 12px; margin-bottom: 14px; align-items: center; }
    .summary-item img { width: 52px; height: 52px; border-radius: 10px; object-fit: cover; background: #0f0f17; flex-shrink: 0; }
    .summary-img-placeholder { width: 52px; height: 52px; border-radius: 10px; background: #12122a; display: flex; align-items: center; justify-content: center; color: #555; flex-shrink: 0; }
    .item-info { flex: 1; }
    .item-name { color: #e0e0e0; font-size: 0.83rem; line-height: 1.4; }
    .item-qty { color: #666; font-size: 0.78rem; }
    .item-price { color: #6c63ff; font-size: 0.88rem; font-weight: 700; flex-shrink: 0; }
    .summary-divider { border: none; border-top: 1px solid #2a2a3e; margin: 16px 0; }
    .summary-row { display: flex; justify-content: space-between; font-size: 0.88rem; color: #aaa; margin-bottom: 10px; }
    .summary-row.grand-total { color: #fff; font-size: 1.1rem; font-weight: 700; margin-top: 14px; }
    .summary-row .val { color: #e0e0e0; }
    .summary-row.grand-total .val { color: #6c63ff; font-size: 1.25rem; }
    .free-ship-badge { background: rgba(46,213,115,0.12); color: #2ed573; font-size: 0.75rem; padding: 3px 9px; border-radius: 6px; }
    .btn-place-order { width: 100%; background: linear-gradient(135deg, #6c63ff, #a855f7); color: #fff; border: none; border-radius: 14px; padding: 15px; font-size: 1rem; font-weight: 700; cursor: pointer; transition: all 0.25s; margin-top: 20px; }
    .btn-place-order:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(108,99,255,0.4); }
    .security-badges { display: flex; justify-content: center; gap: 16px; margin-top: 12px; color: #555; font-size: 0.75rem; }
    .addr-card { background: #12122a; border: 2px solid #2a2a3e; border-radius: 12px; padding: 14px 16px; cursor: pointer; margin-bottom: 10px; transition: border-color 0.2s; position: relative; }
    .addr-card.selected, .addr-card:hover { border-color: #6c63ff; }
    .addr-card input[type=radio] { position: absolute; opacity: 0; }
    .addr-label-tag { background: rgba(108,99,255,0.15); color: #6c63ff; font-size: 0.72rem; padding: 2px 8px; border-radius: 5px; margin-right: 6px; }
    .new-addr-toggle { color: #6c63ff; font-size: 0.88rem; cursor: pointer; margin-top: 4px; }
    .new-addr-toggle:hover { text-decoration: underline; }
    .qr-demo-box { background: #12122a; border: 1px dashed #3a3a5e; border-radius: 14px; padding: 24px; text-align: center; display: none; margin-top: 16px; }
    .qr-demo-box img { width: 140px; height: 140px; border-radius: 10px; }
    .qr-demo-box p { color: #aaa; font-size: 0.82rem; margin-top: 10px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
    .form-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; margin-bottom: 14px; }
    .form-group { margin-bottom: 14px; }
</style>

<div class="checkout-wrap">
    <h1 class="checkout-title">🛒 Thanh toán đơn hàng</h1>
    <p class="checkout-subtitle">Kiểm tra và hoàn tất đơn hàng của bạn</p>

    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background:rgba(255,71,87,0.1);border:1px solid #ff4757;border-radius:12px;padding:14px 18px;color:#ff4757;margin-bottom:20px;">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
        </div>
    }

    <div class="steps-bar">
        <div class="step"><div class="step-num">✓</div><span class="step-label">Giỏ hàng</span></div>
        <div class="step-divider"></div>
        <div class="step"><div class="step-num" style="background:#6c63ff;">2</div><span class="step-label" style="color:#6c63ff;">Thanh toán</span></div>
        <div class="step-divider"></div>
        <div class="step"><div class="step-num" style="background:#2a2a3e;color:#666;">3</div><span class="step-label" style="color:#666;">Hoàn tất</span></div>
    </div>

    <form action="@Url.Action("PlaceOrder", "Cart")" method="post" id="checkout-form">
        @Html.AntiForgeryToken()

        <div class="row">
            <!-- Left Column -->
            <div class="col-md-7">

                <!-- Địa chỉ giao hàng -->
                <div class="card-section">
                    <div class="section-title"><i class="fas fa-map-marker-alt"></i> Địa chỉ giao hàng</div>

                    @if (hasAddresses)
                    {
                        <div id="saved-addresses-block">
                            @foreach (var addr in addresses)
                            {
                                bool isFirst = addresses.First().id == addr.id;
                                <label class="addr-card @(isFirst ? "selected" : "")">
                                    <input type="radio" name="savedAddressId" value="@addr.id" @(isFirst ? "checked=\"checked\"" : "") />
                                    <span class="addr-label-tag">@(addr.label ?? "Địa chỉ")</span>
                                    <strong style="color:#fff;">@addr.receiver_name</strong>
                                    &nbsp;<span style="color:#888;">@addr.receiver_phone</span>
                                    <div style="color:#aaa;font-size:0.82rem;margin-top:4px;">
                                        @addr.street_address, @addr.ward, @addr.district, @addr.province
                                    </div>
                                </label>
                            }
                            <div class="new-addr-toggle" onclick="toggleNewAddr()">
                                <i class="fas fa-plus-circle"></i> Dùng địa chỉ khác
                            </div>
                        </div>

                        <div id="manual-addr-block" style="display:none;margin-top:16px;">
                            <div class="form-row">
                                <div>
                                    <label class="form-label">Họ và tên *</label>
                                    <input name="fullName" class="form-control-dark" placeholder="Nguyễn Văn A" value="@userFullName" />
                                </div>
                                <div>
                                    <label class="form-label">Số điện thoại *</label>
                                    <input name="phone" class="form-control-dark" placeholder="0901234567" value="@userPhone" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Địa chỉ cụ thể *</label>
                                <input name="addressLine" class="form-control-dark" placeholder="123 Đường Lê Lợi" />
                            </div>
                            <div class="form-row-3">
                                <div>
                                    <label class="form-label">Phường/Xã</label>
                                    <input name="ward" class="form-control-dark" placeholder="Phường 1" />
                                </div>
                                <div>
                                    <label class="form-label">Quận/Huyện</label>
                                    <input name="district" class="form-control-dark" placeholder="Quận Bình Thạnh" />
                                </div>
                                <div>
                                    <label class="form-label">Tỉnh/TP</label>
                                    <input name="city" class="form-control-dark" placeholder="TP. Hồ Chí Minh" />
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div id="manual-addr-block">
                            <div class="form-row">
                                <div>
                                    <label class="form-label">Họ và tên *</label>
                                    <input name="fullName" class="form-control-dark" placeholder="Nguyễn Văn A" value="@userFullName" />
                                </div>
                                <div>
                                    <label class="form-label">Số điện thoại *</label>
                                    <input name="phone" class="form-control-dark" placeholder="0901234567" value="@userPhone" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Địa chỉ cụ thể *</label>
                                <input name="addressLine" class="form-control-dark" placeholder="123 Đường Lê Lợi" />
                            </div>
                            <div class="form-row-3">
                                <div>
                                    <label class="form-label">Phường/Xã</label>
                                    <input name="ward" class="form-control-dark" placeholder="Phường 1" />
                                </div>
                                <div>
                                    <label class="form-label">Quận/Huyện</label>
                                    <input name="district" class="form-control-dark" placeholder="Quận Bình Thạnh" />
                                </div>
                                <div>
                                    <label class="form-label">Tỉnh/TP</label>
                                    <input name="city" class="form-control-dark" placeholder="TP. Hồ Chí Minh" />
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Phương thức thanh toán -->
                <div class="card-section">
                    <div class="section-title"><i class="fas fa-credit-card"></i> Phương thức thanh toán</div>
                    <div class="payment-options">
                        <label class="pay-card selected" onclick="selectPayCard(this,'cod')">
                            <input type="radio" name="paymentMethod" value="COD" checked="checked" />
                            <span class="pay-icon">🚚</span>
                            <div class="pay-name">Thanh toán khi nhận hàng</div>
                            <div class="pay-desc">COD - Trả tiền mặt</div>
                        </label>
                        <label class="pay-card" onclick="selectPayCard(this,'bank')">
                            <input type="radio" name="paymentMethod" value="BANK_TRANSFER" />
                            <span class="pay-icon">🏦</span>
                            <div class="pay-name">Chuyển khoản ngân hàng</div>
                            <div class="pay-desc">QR Code tức thì</div>
                        </label>
                        <label class="pay-card" onclick="selectPayCard(this,'momo')">
                            <input type="radio" name="paymentMethod" value="MOMO" />
                            <span class="pay-icon">💜</span>
                            <div class="pay-name">Ví MoMo</div>
                            <div class="pay-desc">Quét QR thanh toán</div>
                        </label>
                    </div>
                    <div class="qr-demo-box" id="qr-demo">
                        <img src="https://api.qrserver.com/v1/create-qr-code/?size=140x140&data=HUIT-SHOP-DEMO" alt="QR" />
                        <p><strong style="color:#fff;">HUIT SHOP — TÀI KHOẢN DEMO</strong><br />
                        Vietcombank | STK: 0123456789<br />Nội dung: THANH TOAN HUIT</p>
                        <span style="color:#ff4757;font-size:0.8rem;">⚠️ Demo — không chuyển tiền thật</span>
                    </div>
                </div>

                <!-- Voucher -->
                <div class="card-section">
                    <div class="section-title"><i class="fas fa-tag"></i> Mã giảm giá</div>
                    <div class="voucher-row">
                        <input type="text" id="voucher-input" class="form-control-dark"
                               placeholder="Nhập mã voucher..." value="@appliedVoucher"
                               style="text-transform:uppercase;" />
                        <button type="button" class="btn-apply" onclick="applyVoucher()">Áp dụng</button>
                        <button type="button" class="btn-apply remove" onclick="removeVoucher()">Xóa</button>
                    </div>
                    <div class="voucher-success" id="voucher-success"></div>
                    <div class="voucher-error" id="voucher-error"></div>
                </div>

                <!-- Ghi chú -->
                <div class="card-section">
                    <div class="section-title"><i class="fas fa-sticky-note"></i> Ghi chú đơn hàng</div>
                    <textarea name="note" class="form-control-dark" rows="3"
                              placeholder="Ghi chú cho người bán (tùy chọn)..."></textarea>
                </div>
            </div>

            <!-- Right: Order Summary -->
            <div class="col-md-5">
                <div class="order-summary">
                    <div class="summary-title">📦 Tóm tắt (@Model.Items.Count sản phẩm)</div>

                    @foreach (var item in Model.Items)
                    {
                        <div class="summary-item">
                            @if (item.Variant != null && !string.IsNullOrEmpty(item.Variant.ThumbnailUrl))
                            {
                                <img src="@item.Variant.ThumbnailUrl" alt="@item.Variant.VariantName" />
                            }
                            else
                            {
                                <div class="summary-img-placeholder"><i class="fas fa-image"></i></div>
                            }
                            <div class="item-info">
                                <div class="item-name">@(item.Variant != null ? item.Variant.VariantName : "Sản phẩm")</div>
                                <div class="item-qty">x@item.Quantity</div>
                            </div>
                            <div class="item-price">@item.LineTotal.ToString("N0")đ</div>
                        </div>
                    }

                    <hr class="summary-divider" />
                    <div class="summary-row">
                        <span>Tạm tính</span>
                        <span class="val" id="subtotal-val">@Model.Subtotal.ToString("N0")đ</span>
                    </div>
                    <div class="summary-row" id="discount-row" style="display:none;">
                        <span>Giảm giá</span>
                        <span class="val" style="color:#2ed573;" id="discount-val">-0đ</span>
                    </div>
                    <div class="summary-row">
                        <span>Phí vận chuyển</span>
                        <span class="val">
                            @if (shippingFee == 0m)
                            {
                                <span class="free-ship-badge">Miễn phí</span>
                            }
                            else
                            {
                                <text>@shippingFee.ToString("N0")đ</text>
                            }
                        </span>
                    </div>
                    <hr class="summary-divider" />
                    <div class="summary-row grand-total">
                        <span>Tổng thanh toán</span>
                        <span class="val" id="total-val">@((Model.Subtotal + shippingFee).ToString("N0"))đ</span>
                    </div>

                    <button type="submit" class="btn-place-order" id="place-order-btn">
                        <i class="fas fa-lock"></i> Đặt hàng ngay
                    </button>

                    <div class="security-badges">
                        <span><i class="fas fa-shield-alt"></i> Bảo mật SSL</span>
                        <span><i class="fas fa-undo"></i> Đổi trả dễ dàng</span>
                        <span><i class="fas fa-headset"></i> Hỗ trợ 24/7</span>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
var subtotal = @Model.Subtotal.ToString(System.Globalization.CultureInfo.InvariantCulture);
var shippingFee = @shippingFee.ToString(System.Globalization.CultureInfo.InvariantCulture);
var currentDiscount = 0;

function updateTotal() {
    var total = subtotal - currentDiscount + shippingFee;
    document.getElementById('total-val').textContent = formatVND(total);
}
function formatVND(n) {
    return Math.round(n).toLocaleString('vi-VN') + 'đ';
}
function selectPayCard(el, type) {
    document.querySelectorAll('.pay-card').forEach(function(c) { c.classList.remove('selected'); });
    el.classList.add('selected');
    el.querySelector('input[type=radio]').checked = true;
    document.getElementById('qr-demo').style.display = (type === 'bank' || type === 'momo') ? 'block' : 'none';
}
function toggleNewAddr() {
    var block = document.getElementById('manual-addr-block');
    if (!block) return;
    block.style.display = block.style.display === 'none' ? 'block' : 'none';
}
function applyVoucher() {
    var code = document.getElementById('voucher-input').value.trim().toUpperCase();
    if (!code) return;
    fetch('@Url.Action("Apply", "Voucher")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'code=' + encodeURIComponent(code)
    }).then(function(r) { return r.json(); }).then(function(data) {
        var ok = document.getElementById('voucher-success');
        var err = document.getElementById('voucher-error');
        if (data.success) {
            currentDiscount = data.discount || 0;
            ok.innerHTML = '<i class="fas fa-check-circle"></i> ' + data.message;
            ok.style.display = 'block';
            err.style.display = 'none';
            document.getElementById('discount-row').style.display = 'flex';
            document.getElementById('discount-val').textContent = '-' + formatVND(currentDiscount);
            updateTotal();
        } else {
            err.innerHTML = '<i class="fas fa-times-circle"></i> ' + data.message;
            err.style.display = 'block';
            ok.style.display = 'none';
        }
    });
}
function removeVoucher() {
    fetch('@Url.Action("Remove", "Voucher")', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            currentDiscount = 0;
            document.getElementById('voucher-input').value = '';
            document.getElementById('voucher-success').style.display = 'none';
            document.getElementById('voucher-error').style.display = 'none';
            document.getElementById('discount-row').style.display = 'none';
            updateTotal();
        });
}
document.getElementById('place-order-btn').addEventListener('click', function() {
    this.disabled = true;
    this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang xử lý...';
});
// Addr card click
document.querySelectorAll('.addr-card').forEach(function(card) {
    card.addEventListener('click', function() {
        document.querySelectorAll('.addr-card').forEach(function(c) { c.classList.remove('selected'); });
        this.classList.add('selected');
        this.querySelector('input[type=radio]').checked = true;
    });
});
</script>
