@using HuitShopDB.Models.DTOs.Product
@{
    ViewBag.Title = "Trang chủ - HUIT Shop";
    var userRole = Session["UserRole"] as string;
    var isAdminOrStaff = userRole == "ADMIN" || userRole == "STAFF";
    var isLoggedIn = Session["UserId"] != null;
    
    var categories = ViewBag.Categories as IEnumerable<CategoryDto> ?? new List<CategoryDto>();
    var products = ViewBag.FeaturedProducts as IEnumerable<ProductListDto> ?? new List<ProductListDto>();
}

<style>
    /* Bố cục Menu & Slider */
    .home-top-section {
        display: flex;
        gap: 15px;
        margin-bottom: 25px;
        margin-top: 10px;
    }
    .cps-sidebar-menu {
        width: 20%;
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.1);
        padding: 10px 0;
        height: fit-content;
    }
    .cps-sidebar-menu a {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 15px;
        color: #333;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 600;
        transition: background 0.2s;
    }
    .cps-sidebar-menu a:hover {
        background: #f3f4f6;
        color: #d70018;
    }
    .cps-sidebar-menu a i.icon-left {
        width: 24px;
        text-align: center;
        margin-right: 8px;
        font-size: 1.1rem;
    }
    .cps-sidebar-menu a i.icon-right {
        font-size: 0.8rem;
        color: #aaa;
    }
    .cps-slider-container {
        width: 80%;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }
    .cps-main-slider {
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0,0,0,0.1);
    }
    .cps-right-banners {
        display: flex;
        gap: 15px;
    }
    .cps-right-banners img {
        width: 100%;
        border-radius: 10px;
        object-fit: cover;
        box-shadow: 0 1px 4px rgba(0,0,0,0.1);
    }
    
    /* Box Tiêu đề Section */
    .cps-block-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 15px;
    }
    .cps-block-title {
        font-size: 1.3rem;
        font-weight: 800;
        text-transform: uppercase;
        color: #222;
        margin: 0;
    }
    
    /* Lưới Sản phẩm */
    .cps-product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 15px;
        margin-bottom: 30px;
    }
    
    /* Khối Admin */
    .admin-panel-section {
        background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
        border: 1px solid #fbbf24;
        border-radius: 10px;
        padding: 1rem 1.5rem;
        margin-bottom: 20px;
    }
</style>

<!-- Top Section: Menu & Banners -->
<div class="home-top-section">
    <!-- Left Sidebar Menu -->
    <div class="cps-sidebar-menu d-none d-xl-block">
        @{
            var icons = new string[] {
                "https://dashboard.cellphones.com.vn/storage/icon-homepage-mobile.svg",
                "https://dashboard.cellphones.com.vn/storage/icon-homepage-laptop.svg",
                "https://dashboard.cellphones.com.vn/storage/icon-homepage-audio-2.svg",
                "https://dashboard.cellphones.com.vn/storage/icon-homepage-watch.svg",
                "https://dashboard.cellphones.com.vn/storage/icon-homepage-home-appliances.svg",
                "https://dashboard.cellphones.com.vn/storage/icon-homepage-accessories.svg",
                "https://dashboard.cellphones.com.vn/storage/icon-homepage-pc.svg",
                "https://dashboard.cellphones.com.vn/storage/icon-homepage-tv.svg",
                "https://dashboard.cellphones.com.vn/storage/icon-homepage-trade-in.svg",
                "https://dashboard.cellphones.com.vn/storage/icon-homepage-promotions.svg"
            };
            int iconIndex = 0;
        }
        @foreach (var cat in categories.Take(10))
        {
            <a href="@Url.Action("Index", "Product", new { categoryId = cat.Id })" class="d-flex align-items-center justify-content-between px-3 py-2 text-dark text-decoration-none fw-semibold" style="transition: background 0.2s;" onmouseover="this.style.background='#f3f4f6';" onmouseout="this.style.background='transparent';">
                <div class="d-flex align-items-center">
                    <img src="@icons[iconIndex % icons.Length]" alt="@cat.Name" style="width: 25px; height: 25px; margin-right: 8px;" />
                    <span style="font-size: 0.8rem;">@cat.Name</span>
                </div>
                <svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 512 512" class="text-muted" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="48" d="m184 112 144 144-144 144"></path></svg>
            </a>
            iconIndex++;
        }
    </div>
    
    <!-- Right Slider & Banners -->
    <div class="cps-slider-container">
        <div id="homeCarousel" class="carousel slide cps-main-slider shadow-sm" data-ride="carousel" style="border-radius: 10px; overflow: hidden;">
            <ol class="carousel-indicators">
                <li data-target="#homeCarousel" data-slide-to="0" class="active"></li>
                <li data-target="#homeCarousel" data-slide-to="1"></li>
            </ol>
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <div class="d-flex align-items-center justify-content-between w-100 px-md-5 px-3" style="height: 220px; background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);">
                        <div class="text-white text-start z-1">
                            <h2 class="fw-bold mb-2" style="font-size: 1.8rem;">iPhone 15 Pro Max</h2>
                            <p class="mb-3 text-info" style="font-size: 1.1rem;">Giảm sốc đến 3 triệu - Trả góp 0%</p>
                            <a href="javascript:void(0)" class="btn btn-outline-light btn-sm px-4 rounded-pill fw-semibold">Mua Ngay</a>
                        </div>
                        <i class="bi bi-apple text-white position-absolute end-0" style="font-size: 8rem; opacity: 0.1; right: 5% !important; pointer-events: none;"></i>
                    </div>
                </div>
                <div class="carousel-item">
                    <div class="d-flex align-items-center justify-content-between w-100 px-md-5 px-3" style="height: 220px; background: linear-gradient(135deg, #1d4ed8 0%, #1e3a8a 100%);">
                        <div class="text-white text-start z-1">
                            <h2 class="fw-bold mb-2" style="font-size: 1.8rem;">Galaxy S24 Ultra</h2>
                            <p class="mb-3 text-warning" style="font-size: 1.1rem;">Quyền năng AI đỉnh cao - Tặng 2 Triệu</p>
                            <a href="javascript:void(0)" class="btn btn-warning text-dark btn-sm px-4 rounded-pill fw-bold">Khám Phá</a>
                        </div>
                        <i class="bi bi-stars text-white position-absolute end-0" style="font-size: 8rem; opacity: 0.1; right: 5% !important; pointer-events: none;"></i>
                    </div>
                </div>
            </div>
            <a class="carousel-control-prev" href="#homeCarousel" role="button" data-slide="prev" style="width: 10%; z-index: 10;">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="sr-only">Previous</span>
            </a>
            <a class="carousel-control-next" href="#homeCarousel" role="button" data-slide="next" style="width: 10%; z-index: 10;">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="sr-only">Next</span>
            </a>
        </div>
        
        <div class="cps-right-banners">
            <div class="d-flex align-items-center justify-content-between w-100 px-4 shadow-sm position-relative overflow-hidden" style="height: 100px; background: linear-gradient(135deg, #d97706 0%, #b45309 100%); border-radius: 10px;">
                <div class="text-white text-start z-1">
                    <h5 class="fw-bold mb-1" style="font-size: 1.1rem;">Laptop Sinh Viên - Trợ Giá Độc Quyền</h5>
                    <p class="mb-0" style="font-size: 0.85rem; opacity: 0.9;">Tặng balo cao cấp & chuột không dây</p>
                </div>
                <i class="bi bi-laptop text-white position-absolute end-0" style="font-size: 5rem; opacity: 0.15; right: 2% !important; pointer-events: none;"></i>
            </div>
        </div>
    </div>
</div>

<!-- Admin Quick Access -->
@if (isAdminOrStaff)
{
    <div class="admin-panel-section">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h6 class="fw-bold text-amber-900 mb-1" style="color:#92400e;">
                    <i class="bi bi-shield-lock me-2" style="color:#d97706;"></i>Bảng điều khiển Admin
                </h6>
                <small class="text-muted">Truy cập nhanh trang quản trị hệ thống</small>
            </div>
            <a href="@Url.Action("Revenue", "Order")" class="btn btn-warning fw-semibold btn-sm px-4" style="border-radius:8px;">
                <i class="bi bi-speedometer2 me-2"></i>Vào trang quản trị
            </a>
        </div>
    </div>
}

<!-- Featured Products Section -->
<div class="cps-block-header">
    <h2 class="cps-block-title">Sản Phẩm Mới Nhất</h2>
</div>

<div class="cps-product-grid">
    @foreach (var p in products)
    {
        string imgUrl = !string.IsNullOrEmpty(p.ThumbnailUrl) ? p.ThumbnailUrl : "https://via.placeholder.com/300x300?text=No+Image";
        decimal price = p.PriceFrom;
        
        <a href="@Url.Action("Detail", "Product", new { id = p.Id })" class="cps-product-card">
            <img src="@imgUrl" class="cps-product-img" alt="@p.Name">
            <div class="cps-product-name">@p.Name</div>
            <div class="cps-product-price">@(price > 0 ? price.ToString("N0") + "đ" : "Liên hệ")</div>
            @if (p.PriceTo.HasValue && p.PriceTo > p.PriceFrom)
            {
                <div class="cps-product-old-price">@p.PriceTo.Value.ToString("N0")đ</div>
            }
            <div class="cps-product-promo">
                <i class="bi bi-gift"></i> Giảm thêm 5% khi quét VNPAY
            </div>
        </a>
    }
</div>

<!-- Extra Banner Footer -->
<div style="margin-bottom: 30px;">
    <img src="https://cdn2.cellphones.com.vn/insecure/rs:fill:1200:75/q:90/plain:https://dashboard.cellphones.com.vn/storage/special-banner-thang-5.png" style="width: 100%; border-radius: 10px;" alt="Footer Banner">
</div>
