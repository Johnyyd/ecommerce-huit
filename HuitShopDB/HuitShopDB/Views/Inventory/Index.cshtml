@model IEnumerable<HuitShopDB.Models.DTOs.Admin.InventoryDto>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var warehouses = ViewBag.Warehouses as IEnumerable<HuitShopDB.Models.warehouse>;
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-box-seam me-2"></i>@ViewBag.Title</h2>
        <div>
            <a href="@Url.Action("Import")" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Nhập kho</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body bg-light">
            <form method="get" class="row g-3 align-items-center">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Chọn kho hàng</label>
                    <select name="warehouseId" class="form-select" onchange="this.form.submit()">
                        <option value="0">Tất cả kho</option>
                        @foreach (var w in warehouses)
                        {
                            <option value="@w.id" @(ViewBag.CurrentWarehouseId == w.id ? "selected" : "")>@w.name (@w.code)</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" name="lowStock" value="true" id="lowStockSwitch" @(ViewBag.LowStockOnly ? "checked" : "") onchange="this.form.submit()">
                        <label class="form-check-label fw-bold" for="lowStockSwitch">Sản phẩm sắp hết hàng</label>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>SKU</th>
                        <th>Sản phẩm</th>
                        <th>Kho</th>
                        <th class="text-center">Số lượng</th>
                        <th class="text-center">Đặt trước</th>
                        <th class="text-center">Khả dụng</th>
                        <th class="text-center">Mức tối thiểu</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            bool isLowStock = item.QuantityOnHand <= item.ReorderPoint;
                            <tr class="@(isLowStock ? "table-warning" : "")">
                                <td class="fw-bold">@item.Sku</td>
                                <td>
                                    <div>@item.ProductName</div>
                                    <small class="text-muted">@item.VariantName</small>
                                </td>
                                <td><span class="badge bg-secondary">@item.WarehouseCode</span></td>
                                <td class="text-center fw-bold">@item.QuantityOnHand</td>
                                <td class="text-center">@item.QuantityReserved</td>
                                <td class="text-center">
                                    <span class="badge @(item.AvailableQuantity > 0 ? "bg-success" : "bg-danger")">
                                        @item.AvailableQuantity
                                    </span>
                                </td>
                                <td class="text-center">@item.ReorderPoint</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary" onclick="openAdjustModal(@item.WarehouseId, @item.VariantId, '@item.ProductName', @item.QuantityOnHand)">
                                        <i class="bi bi-pencil"></i> Điều chỉnh
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">Không tìm thấy dữ liệu tồn kho.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Adjust Stock Modal -->
<div class="modal fade" id="adjustModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Adjust")" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Điều chỉnh tồn kho</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="WarehouseId" id="modalWarehouseId" />
                    <input type="hidden" name="VariantId" id="modalVariantId" />
                    
                    <div class="mb-3">
                        <label class="form-label">Sản phẩm</label>
                        <p id="modalProductName" class="fw-bold"></p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Số lượng hiện tại</label>
                        <input type="text" id="modalCurrentQty" class="form-control" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Thay đổi (+/-)</label>
                        <input type="number" name="QuantityChange" class="form-control" required />
                        <div class="form-text">Ví dụ: 5 để tăng, -3 để giảm.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Lý do/Ghi chú</label>
                        <textarea name="Note" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function openAdjustModal(warehouseId, variantId, productName, currentQty) {
        document.getElementById('modalWarehouseId').value = warehouseId;
        document.getElementById('modalVariantId').value = variantId;
        document.getElementById('modalProductName').innerText = productName;
        document.getElementById('modalCurrentQty').value = currentQty;
        
        var myModal = new bootstrap.Modal(document.getElementById('adjustModal'));
        myModal.show();
    }
</script>
