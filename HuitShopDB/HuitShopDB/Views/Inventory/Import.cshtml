@model HuitShopDB.Models.DTOs.Admin.ImportStockRequest
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var warehouses = ViewBag.Warehouses as IEnumerable<HuitShopDB.Models.warehouse>;
    
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-box-arrow-in-down me-2"></i>Nhập kho sản phẩm</h5>
                </div>
                <div class="card-body p-4">
                    <form action="@Url.Action("Import")" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Chọn kho hàng</label>
                            <select name="WarehouseId" class="form-select" required>
                                <option value="">-- Chọn kho --</option>
                                @foreach (var w in warehouses)
                                {
                                    <option value="@w.id" @(Model.WarehouseId == w.id ? "selected" : "")>@w.name (@w.code)</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Chọn biến thể sản phẩm</label>
                            <select id="variantSelect" name="VariantId" class="form-select" required>
                                <option value="">-- Chọn biến thể sản phẩm --</option>
                                @foreach (var v in ViewBag.Variants as IEnumerable<HuitShopDB.Models.product_variant>)
                                {
                                    var displayName = v.product.name + (string.IsNullOrEmpty(v.variant_name) || v.variant_name == "Mặc định" ? "" : " - " + v.variant_name) + " (" + v.sku + ")";
                                    var costPrice = v.cost_price ?? 0;
                                    var price = v.price;
                                    <option value="@v.id" data-cost-price="@((long)costPrice)" data-price="@((long)price)" @(Model.VariantId == v.id ? "selected" : "")>@displayName</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Số lượng nhập</label>
                            <input type="number" name="Quantity" class="form-control" value="1" min="1" required />
                            <small class="text-muted">Nếu không nhập mã serial, hệ thống sẽ sử dụng số lượng này.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Giá nhập (VNĐ)</label>
                            <input type="number" id="costPriceInput" name="CostPrice" class="form-control" value="0" step="1000" />
                            <div id="costPriceHelp" class="form-text text-muted mt-2" style="display:none;">
                                <span class="badge bg-secondary me-2 p-2 text-white" style="color: #fff !important;"><i class="bi bi-tag-fill me-1"></i>Giá nhập tiêu chuẩn (cũ): <span id="oldCostPriceText">0</span> VNĐ</span>
                                <span class="badge bg-info text-dark p-2" style="color: #212529 !important;"><i class="bi bi-cart-dash-fill me-1"></i>Giá bán lẻ hiện tại: <span id="retailPriceText">0</span> VNĐ</span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mã Serial (Mỗi mã 1 dòng)</label>
                            <textarea name="SerialsRaw" class="form-control" rows="5" placeholder="Nhập danh sách mã serial nếu có..."></textarea>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">Xác nhận nhập kho</button>
                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var variantSelect = document.getElementById("variantSelect");
        var costPriceInput = document.getElementById("costPriceInput");
        var costPriceHelp = document.getElementById("costPriceHelp");
        var oldCostPriceText = document.getElementById("oldCostPriceText");
        var retailPriceText = document.getElementById("retailPriceText");

        function formatNumber(num) {
            return new Intl.NumberFormat('vi-VN').format(num);
        }

        function updateCostPriceInfo() {
            var selectedOption = variantSelect.options[variantSelect.selectedIndex];
            if (selectedOption && selectedOption.value) {
                var costPrice = parseFloat(selectedOption.getAttribute("data-cost-price")) || 0;
                var price = parseFloat(selectedOption.getAttribute("data-price")) || 0;

                // Auto-fill cost price if current input is 0 or empty
                if (costPriceInput.value == "0" || costPriceInput.value == "") {
                    costPriceInput.value = costPrice;
                }

                oldCostPriceText.innerText = formatNumber(costPrice);
                retailPriceText.innerText = formatNumber(price);
                costPriceHelp.style.display = "block";
            } else {
                costPriceHelp.style.display = "none";
            }
        }

        variantSelect.addEventListener("change", updateCostPriceInfo);
        
        // Trigger once on load in case a variant is pre-selected
        if (variantSelect.value) {
            updateCostPriceInfo();
        }
    });
</script>
