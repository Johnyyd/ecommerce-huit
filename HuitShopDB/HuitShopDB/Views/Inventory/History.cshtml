@model IEnumerable<HuitShopDB.Models.DTOs.Admin.StockMovementDto>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold"><i class="bi bi-clock-history me-2"></i>@ViewBag.Title</h2>
            <p class="text-muted mb-0">Xem lại hoạt động nhập, điều chỉnh và chuyển kho.</p>
        </div>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Quay lại kho hàng</a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body bg-light">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Kho hàng</label>
                    <select name="warehouseId" class="form-select" onchange="this.form.submit()">
                        <option value="0">Tất cả kho</option>
                        @foreach (var w in ViewBag.Warehouses as IEnumerable<HuitShopDB.Models.warehouse>)
                        {
                            <option value="@w.id" @(ViewBag.CurrentWarehouseId == w.id ? "selected" : "")>@w.name (@w.code)</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">ID biến thể</label>
                    <input type="number" name="variantId" class="form-control" value="@(ViewBag.CurrentVariantId ?? 0)" placeholder="Nhập ID biến thể" />
                </div>
                <div class="col-md-4 d-grid">
                    <button type="submit" class="btn btn-primary">Lọc</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Thời gian</th>
                        <th>Kho</th>
                        <th>Sản phẩm</th>
                        <th>SKU</th>
                        <th class="text-center">Số lượng</th>
                        <th>Loại</th>
                        <th>Ghi chú</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-nowrap">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.WarehouseName</td>
                                <td>@item.ProductName</td>
                                <td>@item.Sku</td>
                                <td class="text-center fw-bold">@item.Quantity</td>
                                <td>
                                    <span class="badge bg-secondary">@item.MovementType</span>
                                </td>
                                <td>@item.Note</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">Chưa có dữ liệu lịch sử tồn kho.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
