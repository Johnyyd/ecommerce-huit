@model HuitShopDB.Models.DTOs.Admin.RevenueStatisticsDto
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Báo cáo thống kê doanh thu";
    var recentOrders = ViewBag.RecentOrders as IEnumerable<HuitShopDB.Models.DTOs.Order.OrderResponseDto>;
}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-graph-up-arrow text-primary me-2"></i>Thống kê doanh thu
            </h2>
            <p class="text-secondary mb-0">Theo dõi doanh thu, đơn hàng và hiệu suất bán hàng của hệ thống.</p>
        </div>
        <div>
            <a href="@Url.Action("Manage")" class="btn btn-outline-secondary px-3 rounded-pill">
                <i class="bi bi-list-task me-1"></i>Quản lý đơn hàng
            </a>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="card shadow-sm border-0 mb-4 bg-white" style="border-radius: 1rem;">
        <div class="card-body p-3">
            <form method="get" action="@Url.Action("Revenue")" id="filterForm" class="row g-3 align-items-center">
                <div class="col-md-3">
                    <label class="form-label text-muted small fw-bold">Mốc thời gian</label>
                    <select name="preset" id="presetSelect" class="form-select rounded-pill">
                        <option value="TODAY" @(Model.DatePreset == "TODAY" ? "selected" : "")>Hôm nay</option>
                        <option value="YESTERDAY" @(Model.DatePreset == "YESTERDAY" ? "selected" : "")>Hôm qua</option>
                        <option value="LAST_7_DAYS" @(Model.DatePreset == "LAST_7_DAYS" ? "selected" : "")>7 ngày qua</option>
                        <option value="THIS_MONTH" @(Model.DatePreset == "THIS_MONTH" ? "selected" : "")>Tháng này</option>
                        <option value="LAST_MONTH" @(Model.DatePreset == "LAST_MONTH" ? "selected" : "")>Tháng trước</option>
                        <option value="THIS_YEAR" @(Model.DatePreset == "THIS_YEAR" ? "selected" : "")>Năm nay</option>
                        <option value="CUSTOM" @(Model.DatePreset == "CUSTOM" ? "selected" : "")>Tùy chọn ngày</option>
                    </select>
                </div>
                
                <div class="col-md-3 custom-date-group" style="display: none;">
                    <label class="form-label text-muted small fw-bold">Từ ngày</label>
                    <input type="date" name="startDate" id="startDateInput" class="form-control rounded-pill" value="@(Model.StartDate.ToString("yyyy-MM-dd"))" />
                </div>
                
                <div class="col-md-3 custom-date-group" style="display: none;">
                    <label class="form-label text-muted small fw-bold">Đến ngày</label>
                    <input type="date" name="endDate" id="endDateInput" class="form-control rounded-pill" value="@(Model.EndDate.ToString("yyyy-MM-dd"))" />
                </div>
                
                <div class="col-md-3 align-self-end">
                    <button type="submit" class="btn btn-primary px-4 rounded-pill w-100 fw-bold">
                        <i class="bi bi-filter me-1"></i>Áp dụng
                    </button>
                </div>
                
                <div class="col-md text-md-end text-muted small align-self-end pb-2">
                    Kỳ thống kê: <strong>@Model.StartDate.ToString("dd/MM/yyyy")</strong> - <strong>@Model.EndDate.ToString("dd/MM/yyyy")</strong>
                </div>
            </form>
        </div>
    </div>

    <!-- KPI Summary Cards -->
    <div class="row g-3 mb-4">
        <!-- Revenue Card -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 overflow-hidden" style="background: linear-gradient(135deg, #4f46e5 0%, #3b82f6 100%); color: white; border-radius: 1rem;">
                <div class="card-body p-4 position-relative">
                    <div class="position-absolute" style="right: 15px; bottom: 10px; opacity: 0.15;">
                        <i class="bi bi-currency-dollar" style="font-size: 5rem;"></i>
                    </div>
                    <span class="text-white-50 small fw-bold">DOANH THU THỰC TẾ</span>
                    <h3 class="fw-bold mt-2 mb-1">@Model.TotalRevenue.ToString("N0")đ</h3>
                    <p class="mb-0 text-white-50 small">
                        <i class="bi bi-info-circle me-1"></i>Từ đơn hàng đã hoàn tất
                    </p>
                </div>
            </div>
        </div>

        <!-- Orders Card -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 overflow-hidden" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; border-radius: 1rem;">
                <div class="card-body p-4 position-relative">
                    <div class="position-absolute" style="right: 15px; bottom: 10px; opacity: 0.15;">
                        <i class="bi bi-cart-check" style="font-size: 5rem;"></i>
                    </div>
                    <span class="text-white-50 small fw-bold">ĐƠN HÀNG HOÀN THÀNH</span>
                    <h3 class="fw-bold mt-2 mb-1">@Model.CompletedOrdersCount / @Model.TotalOrders</h3>
                    <p class="mb-0 text-white-50 small">
                        Tỷ lệ thành công: @(Model.TotalOrders > 0 ? ((double)Model.CompletedOrdersCount / Model.TotalOrders * 100).ToString("F1") : "0")%
                    </p>
                </div>
            </div>
        </div>

        <!-- Products Sold Card -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 overflow-hidden" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white; border-radius: 1rem;">
                <div class="card-body p-4 position-relative">
                    <div class="position-absolute" style="right: 15px; bottom: 10px; opacity: 0.15;">
                        <i class="bi bi-box-seam" style="font-size: 5rem;"></i>
                    </div>
                    <span class="text-white-50 small fw-bold">SẢN PHẨM ĐÃ BÁN</span>
                    <h3 class="fw-bold mt-2 mb-1">@Model.TotalProductsSold.ToString("N0")</h3>
                    <p class="mb-0 text-white-50 small">
                        <i class="bi bi-tag-fill me-1"></i>Từ đơn hàng đã hoàn tất
                    </p>
                </div>
            </div>
        </div>

        <!-- AOV Card -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100 overflow-hidden" style="background: linear-gradient(135deg, #ec4899 0%, #db2777 100%); color: white; border-radius: 1rem;">
                <div class="card-body p-4 position-relative">
                    <div class="position-absolute" style="right: 15px; bottom: 10px; opacity: 0.15;">
                        <i class="bi bi-calculator" style="font-size: 5rem;"></i>
                    </div>
                    <span class="text-white-50 small fw-bold">ĐƠN HÀNG TRUNG BÌNH (AOV)</span>
                    <h3 class="fw-bold mt-2 mb-1">@Model.AverageOrderValue.ToString("N0")đ</h3>
                    <p class="mb-0 text-white-50 small">
                        Giảm giá voucher: -@Model.TotalDiscount.ToString("N0")đ
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Secondary KPI summary -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100 bg-white" style="border-radius: 1rem;">
                <div class="card-body p-3 d-flex align-items-center">
                    <div class="rounded-circle bg-light-warning text-warning d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; background: rgba(245, 158, 11, 0.15);">
                        <i class="bi bi-hourglass-split fs-4"></i>
                    </div>
                    <div>
                        <span class="text-secondary small fw-semibold d-block">Doanh thu chờ xử lý/vận chuyển</span>
                        <span class="fs-5 fw-bold text-dark">@Model.PendingRevenue.ToString("N0")đ</span>
                        <span class="badge bg-warning ms-2">@Model.PendingOrdersCount đơn hàng</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100 bg-white" style="border-radius: 1rem;">
                <div class="card-body p-3 d-flex align-items-center">
                    <div class="rounded-circle bg-light-danger text-danger d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; background: rgba(239, 68, 68, 0.15);">
                        <i class="bi bi-x-circle fs-4"></i>
                    </div>
                    <div>
                        <span class="text-secondary small fw-semibold d-block">Đơn hàng bị hủy</span>
                        <span class="fs-5 fw-bold text-dark">@Model.CancelledOrdersCount đơn hàng</span>
                        <span class="text-muted small">Tỷ lệ hủy: @(Model.TotalOrders > 0 ? ((double)Model.CancelledOrdersCount / Model.TotalOrders * 100).ToString("F1") : "0")%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Graphs and Charts -->
    <div class="row g-4 mb-4">
        <!-- Revenue Line Chart -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100 bg-white" style="border-radius: 1rem;">
                <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-graph-up me-2 text-primary"></i>Biểu đồ xu hướng doanh thu</h5>
                    <span class="text-muted small">Chỉ tính đơn hàng hoàn thành</span>
                </div>
                <div class="card-body">
                    <div style="position: relative; height: 350px;">
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Status Distribution Doughnut Chart -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 h-100 bg-white" style="border-radius: 1rem;">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-pie-chart me-2 text-primary"></i>Trạng thái đơn hàng</h5>
                </div>
                <div class="card-body d-flex flex-column justify-content-center align-items-center">
                    <div style="position: relative; height: 230px; width: 100%;">
                        <canvas id="statusChart"></canvas>
                    </div>
                    <div class="mt-3 w-100">
                        <div class="row g-2 justify-content-center text-center">
                            <div class="col-6">
                                <span class="d-inline-block rounded-circle bg-success me-1" style="width: 10px; height: 10px;"></span>
                                <small class="text-muted">Hoàn thành: <strong>@Model.CompletedOrdersCount</strong></small>
                            </div>
                            <div class="col-6">
                                <span class="d-inline-block rounded-circle bg-warning me-1" style="width: 10px; height: 10px;"></span>
                                <small class="text-muted">Chờ/Đang giao: <strong>@Model.PendingOrdersCount</strong></small>
                            </div>
                            <div class="col-6">
                                <span class="d-inline-block rounded-circle bg-danger me-1" style="width: 10px; height: 10px;"></span>
                                <small class="text-muted">Đã hủy: <strong>@Model.CancelledOrdersCount</strong></small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Top Products List -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100 bg-white" style="border-radius: 1rem;">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-trophy me-2 text-warning"></i>Top 10 sản phẩm bán chạy nhất</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Sản phẩm</th>
                                <th class="text-center">SKU</th>
                                <th class="text-center">Số lượng bán</th>
                                <th class="text-end pe-4">Doanh thu thu về</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.TopSellingProducts != null && Model.TopSellingProducts.Any())
                            {
                                int rank = 1;
                                foreach (var p in Model.TopSellingProducts)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <span class="badge bg-light text-dark border me-3 d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; font-weight: bold; border-radius: 50%;">
                                                    @rank
                                                </span>
                                                <img src="@(string.IsNullOrEmpty(p.ThumbnailUrl) ? "https://via.placeholder.com/40" : p.ThumbnailUrl)" class="rounded border me-2" style="width: 40px; height: 40px; object-fit: cover;" />
                                                <div class="text-dark fw-bold">@p.ProductName</div>
                                            </div>
                                        </td>
                                        <td class="text-center font-monospace small">@p.Sku</td>
                                        <td class="text-center fw-bold">@p.QuantitySold.ToString("N0")</td>
                                        <td class="text-end fw-bold text-danger pe-4">@p.TotalSales.ToString("N0")đ</td>
                                    </tr>
                                    rank++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">Chưa có dữ liệu bán hàng cho kỳ này.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Recent Orders & Category Sales -->
        <div class="col-lg-4 d-flex flex-column gap-4">
            <!-- Category Sales Card -->
            <div class="card shadow-sm border-0 bg-white" style="border-radius: 1rem;">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-tags me-2 text-primary"></i>Doanh thu theo danh mục</h5>
                </div>
                <div class="card-body p-3">
                    @if (Model.TopCategories != null && Model.TopCategories.Any())
                    {
                        foreach (var cat in Model.TopCategories)
                        {
                            decimal percentage = Model.TotalRevenue > 0 ? (cat.TotalSales / Model.TotalRevenue * 100) : 0;
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="small fw-bold">@cat.CategoryName</span>
                                    <span class="small text-muted">@cat.TotalSales.ToString("N0")đ (@percentage.ToString("F1")%)</span>
                                </div>
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar bg-primary" role="progressbar" style="width: @(percentage)%;" aria-valuenow="@(percentage)" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted small">Không có dữ liệu phân loại.</div>
                    }
                </div>
            </div>

            <!-- Recent Orders Card -->
            <div class="card shadow-sm border-0 bg-white" style="border-radius: 1rem; flex-grow: 1;">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-clock-history me-2 text-primary"></i>Đơn hàng mới nhất</h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @if (recentOrders != null && recentOrders.Any())
                        {
                            foreach (var order in recentOrders)
                            {
                                <div class="list-group-item p-3 border-0 border-bottom">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <a href="@Url.Action("AdminDetails", new { id = order.Id })" class="fw-bold font-monospace text-decoration-none">@order.Code</a>
                                        @if (order.Status == "COMPLETED")
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle">Thành công</span>
                                        }
                                        else if (order.Status == "CANCELLED")
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Đã hủy</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning-subtle text-warning border border-warning-subtle">Chờ/Đang giao</span>
                                        }
                                    </div>
                                    <div class="d-flex justify-content-between text-muted small">
                                        <span>@order.RecipientName</span>
                                        <span class="fw-bold text-dark">@order.Total.ToString("N0")đ</span>
                                    </div>
                                    <div class="text-muted small mt-0.5" style="font-size: 0.75rem;">
                                        @order.CreatedAt.AddHours(7).ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-4 text-muted small">Không có đơn hàng nào trong kỳ này.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Toggle custom date range inputs depending on preset
            const presetSelect = document.getElementById("presetSelect");
            const customDateGroups = document.querySelectorAll(".custom-date-group");

            function toggleCustomDates() {
                if (presetSelect.value === "CUSTOM") {
                    customDateGroups.forEach(el => el.style.display = "block");
                } else {
                    customDateGroups.forEach(el => el.style.display = "none");
                }
            }

            presetSelect.addEventListener("change", function() {
                toggleCustomDates();
                // Auto submit if not custom
                if (presetSelect.value !== "CUSTOM") {
                    document.getElementById("filterForm").submit();
                }
            });

            // Initial load toggle
            toggleCustomDates();

            // --- CHARTS ---
            
            // 1. Revenue Chart
            const dailyData = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.DailyRevenue));
            const revenueLabels = dailyData.map(item => {
                const parts = item.Date.split('-');
                return parts.length === 3 ? `${parts[2]}/${parts[1]}` : item.Date;
            });
            const revenueValues = dailyData.map(item => item.Revenue);
            const orderCounts = dailyData.map(item => item.OrderCount);

            const ctxRevenue = document.getElementById('revenueChart').getContext('2d');
            
            const gradient = ctxRevenue.createLinearGradient(0, 0, 0, 300);
            gradient.addColorStop(0, 'rgba(59, 130, 246, 0.4)');
            gradient.addColorStop(1, 'rgba(59, 130, 246, 0.01)');

            new Chart(ctxRevenue, {
                type: 'line',
                data: {
                    labels: revenueLabels.length > 0 ? revenueLabels : ['Không có dữ liệu'],
                    datasets: [{
                        label: 'Doanh thu (VNĐ)',
                        data: revenueValues.length > 0 ? revenueValues : [0],
                        borderColor: '#3b82f6',
                        borderWidth: 3,
                        backgroundColor: gradient,
                        fill: true,
                        tension: 0.3,
                        pointBackgroundColor: '#3b82f6',
                        pointHoverRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.parsed.y !== null) {
                                        label += new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(context.parsed.y);
                                    }
                                    const index = context.dataIndex;
                                    if (orderCounts[index] !== undefined) {
                                        label += ` (${orderCounts[index]} đơn hàng)`;
                                    }
                                    return label;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(0, 0, 0, 0.05)'
                            },
                            ticks: {
                                callback: function(value) {
                                    if (value >= 1000000) {
                                        return (value / 1000000) + 'M';
                                    } else if (value >= 1000) {
                                        return (value / 1000) + 'k';
                                    }
                                    return value;
                                }
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            }
                        }
                    }
                }
            });

            // 2. Order Status Chart
            const ctxStatus = document.getElementById('statusChart').getContext('2d');
            const completedCount = @Model.CompletedOrdersCount;
            const pendingCount = @Model.PendingOrdersCount;
            const cancelledCount = @Model.CancelledOrdersCount;

            new Chart(ctxStatus, {
                type: 'doughnut',
                data: {
                    labels: ['Hoàn thành', 'Chờ xử lý / Đang giao', 'Đã hủy'],
                    datasets: [{
                        data: [completedCount, pendingCount, cancelledCount],
                        backgroundColor: ['#10b981', '#f59e0b', '#ef4444'],
                        borderWidth: 2,
                        borderColor: '#ffffff',
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    cutout: '70%'
                }
            });
        });
    </script>
}
