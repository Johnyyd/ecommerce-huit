@model HuitShopDB.Models.DTOs.User.UpdateProfileRequest

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Cập nhật hồ sơ tài khoản</h4>
        </div>
        <div class="card-body">
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-bold">ID tài khoản</label>
                    <input type="text" class="form-control bg-light" value="@ViewBag.UserId" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Email</label>
                    <input type="text" class="form-control bg-light" value="@ViewBag.Email" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Quyền hạn hiện tại</label>
                    <input type="text" class="form-control bg-light" value="@ViewBag.Role" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Họ và tên mới</label>
                    @Html.TextBoxFor(m => m.FullName, new { @class = "form-control" })
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Đường dẫn ảnh đại diện (Avatar URL)</label>
                    @Html.TextBoxFor(m => m.AvatarUrl, new { @class = "form-control" })
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a href="javascript:history.back()" class="btn btn-outline-secondary">Quay lại</a>
                    <button type="submit" class="btn btn-success">Lưu thay đổi</button>
                </div>
            }
        </div>
    </div>
</div>