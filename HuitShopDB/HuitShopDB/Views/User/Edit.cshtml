@model HuitShopDB.Models.DTOs.User.UserDto
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-person-gear me-2"></i>@ViewBag.Title</h5>
                </div>
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="avatar bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2" style="width: 80px; height: 80px; font-size: 2rem;">
                            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                            {
                                <img src="@Model.AvatarUrl" class="rounded-circle" style="width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                @(Model.FullName.Substring(0, 1).ToUpper())
                            }
                        </div>
                        <h4 class="mb-1">@Model.FullName</h4>
                        <p class="text-muted">@Model.Email</p>
                    </div>

                    <form action="@Url.Action("Edit")" method="post">
                        @Html.HiddenFor(m => m.Id)
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Vai trò hệ thống</label>
                            <select name="role" class="form-select" required>
                                <option value="USER" @(Model.Role == "USER" ? "selected" : "")>USER - Người dùng thông thường</option>
                                <option value="ADMIN" @(Model.Role == "ADMIN" ? "selected" : "")>ADMIN - Quản trị viên</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Trạng thái tài khoản</label>
                            <select name="status" class="form-select" required>
                                <option value="ACTIVE" @(Model.Status == "ACTIVE" ? "selected" : "")>Đang hoạt động</option>
                                <option value="SUSPENDED" @(Model.Status == "SUSPENDED" ? "selected" : "")>Đã khóa / Đình chỉ</option>
                            </select>
                        </div>

                        <div class="alert alert-info small">
                            <i class="bi bi-info-circle me-1"></i> 
                            Cập nhật vai trò sẽ ảnh hưởng ngay lập tức đến quyền truy cập của người dùng này vào các trang quản lý.
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg text-white font-weight-bold">
                                Lưu thay đổi
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Trở lại danh sách</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
