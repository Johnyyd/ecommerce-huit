@model IEnumerable<HuitShopDB.Models.DTOs.User.UserDto>

@{
    ViewBag.Title = ViewBag.Title ?? "Danh sách người dùng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2>@ViewBag.Title</h2>
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Họ tên</th>
                <th>Email</th>
                <th>Chức vụ</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.FullName</td>
                    <td>@item.Email</td>
                    <td>@item.Role</td>
                    <td>@item.Status</td>
                    <td>
                        <a href="@Url.Action("Edit", "User", new { id = item.Id })" class="btn btn-sm btn-warning">Sửa</a>
                        <a href="@Url.Action("Delete", "User", new { id = item.Id })" class="btn btn-sm btn-danger" onclick="return confirm('Bạn chắc chắn muốn xóa?');">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>