@model HuitShopDB.Models.DTOs.Warranty.WarrantyClaimRequest
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-danger text-white py-4">
                    <h4 class="mb-0"><i class="bi bi-exclamation-octagon me-2"></i>Gửi yêu cầu bảo hành</h4>
                    <small>Chúng tôi sẽ giải quyết vấn đề của bạn một cách nhanh chóng</small>
                </div>

                <div class="card-body p-4">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Vui lòng kiểm tra lại thông tin nhập vào.
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form action="@Url.Action("SubmitClaim")" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <!-- Warranty Info Alert -->
                        <div class="alert alert-info mb-4">
                            <div class="row">
                                <div class="col-md-6">
                                    <strong>Số serial:</strong> @ViewBag.WarrantyInfo?.SerialNumber
                                </div>
                                <div class="col-md-6">
                                    <strong>Sản phẩm:</strong> @ViewBag.WarrantyInfo?.ProductName
                                </div>
                            </div>
                            <div class="row mt-2">
                                <div class="col-md-6">
                                    <strong>Ngày mua:</strong> @ViewBag.WarrantyInfo?.OutboundDate.ToString("dd/MM/yyyy")
                                </div>
                                <div class="col-md-6">
                                    <strong>Hết hạn:</strong> @ViewBag.WarrantyInfo?.ExpireDate?.ToString("dd/MM/yyyy")
                                </div>
                            </div>
                        </div>

                        @Html.HiddenFor(m => m.SerialNumber)

                        <!-- Claim Type -->
                        <div class="mb-4">
                            <label class="form-label fw-bold mb-3">Loại yêu cầu</label>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="ClaimType" value="REPAIR" id="repair" required>
                                        <label class="form-check-label" for="repair">
                                            <strong>Sửa chữa</strong>
                                            <br><small class="text-muted">Sản phẩm hỏng, cần sửa</small>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="ClaimType" value="REPLACEMENT" id="replacement">
                                        <label class="form-check-label" for="replacement">
                                            <strong>Thay thế</strong>
                                            <br><small class="text-muted">Yêu cầu sản phẩm mới</small>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="ClaimType" value="REFUND" id="refund">
                                        <label class="form-check-label" for="refund">
                                            <strong>Hoàn tiền</strong>
                                            <br><small class="text-muted">Yêu cầu hoàn lại tiền</small>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Issue Description -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">Mô tả chi tiết vấn đề</label>
                            <textarea name="IssueDescription" class="form-control" rows="5" 
                                      placeholder="Vui lòng mô tả chi tiết vấn đề gặp phải..."
                                      required>@Model.IssueDescription</textarea>
                            <small class="text-muted">Vui lòng cung cấp thông tin chi tiết để giúp chúng tôi xử lý nhanh chóng</small>
                        </div>

                        <!-- Photos/Evidence -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">Hình ảnh minh chứng (Tối đa 5 ảnh)</label>
                            <div class="input-group input-group-lg mb-3">
                                <input type="file" class="form-control" accept="image/*" multiple id="photoUpload" />
                            </div>
                            <div id="photoPreview" class="row g-2"></div>
                            <small class="text-muted">Hình ảnh rõ ràng sẽ giúp chúng tôi xử lý nhanh hơn</small>
                        </div>

                        <!-- Warranty Status -->
                        <div class="alert alert-warning mb-4">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Lưu ý:</strong> 
                            @if (ViewBag.WarrantyValid)
                            {
                                <span>Sản phẩm của bạn vẫn còn trong thời gian bảo hành. Chúng tôi sẽ xử lý yêu cầu này sớm.</span>
                            }
                            else
                            {
                                <span>Sản phẩm của bạn đã hết hạn bảo hành. Chúng tôi vẫn có thể giúp bạn nhưng có thể phải tính phí.</span>
                            }
                        </div>

                        <!-- Buttons -->
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="bi bi-send me-2"></i>Gửi yêu cầu bảo hành
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Info Section -->
            <div class="card border-0 mt-4 bg-light">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-question-circle me-2"></i>Quy trình xử lý bảo hành</h6>
                    <div class="timeline">
                        <div class="timeline-item mb-3">
                            <span class="badge bg-primary rounded-pill">1</span>
                            <strong>Gửi yêu cầu</strong> - Bạn gửi thông tin về vấn đề
                        </div>
                        <div class="timeline-item mb-3">
                            <span class="badge bg-primary rounded-pill">2</span>
                            <strong>Kiểm duyệt</strong> - Chúng tôi kiểm tra yêu cầu của bạn
                        </div>
                        <div class="timeline-item mb-3">
                            <span class="badge bg-primary rounded-pill">3</span>
                            <strong>Phê duyệt</strong> - Chúng tôi sẽ phê duyệt hoặc liên hệ bạn
                        </div>
                        <div class="timeline-item">
                            <span class="badge bg-primary rounded-pill">4</span>
                            <strong>Hoàn thành</strong> - Xử lý yêu cầu của bạn
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('photoUpload').addEventListener('change', function(e) {
    const preview = document.getElementById('photoPreview');
    preview.innerHTML = '';
    
    Array.from(this.files).slice(0, 5).forEach(file => {
        const reader = new FileReader();
        reader.onload = function(e) {
            const col = document.createElement('div');
            col.className = 'col-md-3';
            col.innerHTML = `<img src="${e.target.result}" class="img-fluid rounded border">`;
            preview.appendChild(col);
        };
        reader.readAsDataURL(file);
    });
});
</script>
