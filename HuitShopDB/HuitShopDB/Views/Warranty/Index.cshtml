@model IEnumerable<HuitShopDB.Models.DTOs.Warranty.WarrantyDto>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <!-- Hero / Search Section -->
    <div class="row justify-content-center mb-5">
        <div class="col-md-8 text-center">
            <h1 class="fw-bold display-5 mb-3"><i class="bi bi-shield-check text-primary me-2"></i>Tra cứu bảo hành</h1>
            <p class="lead text-muted mb-4">Nhập mã Serial Number của thiết bị để kiểm tra thời hạn và thông tin bảo hành chính hãng.</p>
            
            <form action="@Url.Action("Index")" method="get" class="card shadow-lg border-0 p-2 rounded-pill">
                <div class="input-group input-group-lg">
                    <input type="text" name="serialNumber" class="form-control border-0 bg-transparent ps-4" placeholder="Ví dụ: IP15PRO-123456" required />
                    <button type="submit" class="btn btn-primary rounded-pill px-5 mx-1">
                        <i class="bi bi-search me-2"></i> Kiểm tra ngay
                    </button>
                </div>
            </form>
            
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger mt-3 rounded-pill">
                    <i class="bi bi-exclamation-circle me-2"></i>@ViewBag.ErrorMessage
                </div>
            }
        </div>
    </div>

    <!-- Recent Warranties Table -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2"></i>Các sản phẩm vừa kích hoạt</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Serial Number</th>
                                <th>Sản phẩm</th>
                                <th>Ngày mua</th>
                                <th>Hết hạn</th>
                                <th class="text-center">Trạng thái</th>
                                <th class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="fw-bold">@item.SerialNumber</td>
                                        <td>
                                            <div>@item.ProductName</div>
                                            <small class="text-muted">@item.VariantName</small>
                                        </td>
                                        <td>@(item.OutboundDate.HasValue ? item.OutboundDate.Value.ToString("dd/MM/yyyy") : "-")</td>
                                        <td>@(item.ExpireDate.HasValue ? item.ExpireDate.Value.ToString("dd/MM/yyyy") : "-")</td>
                                        <td class="text-center">
                                            @if (item.Status == "ACTIVE")
                                            {
                                                <span class="badge bg-success-subtle text-success border border-success-subtle">Còn hạn (@item.DaysRemaining ngày)</span>
                                            }
                                            else if (item.Status == "EXPIRED")
                                            {
                                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Hết hạn</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">@item.Status</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <a href="@Url.Action("Details", new { serial = item.SerialNumber })" class="btn btn-sm btn-outline-primary">
                                                Chi tiết <i class="bi bi-arrow-right"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">Không có dữ liệu bảo hành gần đây.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
