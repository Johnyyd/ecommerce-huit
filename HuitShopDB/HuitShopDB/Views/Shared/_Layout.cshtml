<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <title>@ViewBag.Title - ECommerce HUIT</title>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
    <link rel="stylesheet" href="@Url.Content("~/Content/bootstrap/css/bootstrap.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Content/Site.css")" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <style>
        body {
            min-height: 100vh;
            padding-top: 74px;
            background: #f6f7fb;
            color: #22303c;
        }
        .navbar-brand {
            font-weight: 700;
            letter-spacing: 0.04em;
        }
        .body-content {
            padding: 24px 0 48px;
        }
        .page-header {
            margin-bottom: 1.75rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid rgba(33,37,41,.08);
        }
        .footer-brand {
            opacity: 0.7;
        }
        .card {
            border-radius: 1rem;
        }
        .btn-outline-primary:hover,
        .btn-outline-success:hover,
        .btn-outline-warning:hover,
        .btn-outline-info:hover {
            transform: translateY(-1px);
            transition: transform 0.2s ease;
        }
        .avatar {
            min-width: 48px;
        }
        .alert-dismissible .btn-close {
            top: 1rem;
            right: 1rem;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top shadow-sm">
        <div class="container">
            <a class="navbar-brand" href="/">HUIT Shop</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Chuyển đổi điều hướng">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Product">Sản phẩm</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Inventory">Kho hàng</a></li>
                    <li class="nav-item"><a class="nav-link" href="/User">Người dùng</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Review">Đánh giá</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Warranty">Bảo hành</a></li>
                </ul>
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" href="/Home/About">Về chúng tôi</a></li>
                </ul>
            </div>
        </div>
    </nav>
    <main class="container body-content">
        @RenderBody()
        <hr class="my-5" />
        <footer class="pb-4 text-muted small d-flex flex-column flex-md-row justify-content-between align-items-center">
            <div>&copy; @DateTime.Now.Year ECommerce HUIT</div>
            <div class="footer-brand">Thiết kế thân thiện cho quản trị và người dùng.</div>
        </footer>
    </main>
    <script src="@Url.Content("~/Content/bootstrap/js/bootstrap.bundle.min.js")"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>

