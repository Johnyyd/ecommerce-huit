<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <title>@ViewBag.Title - ECommerce HUIT</title>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
    <link rel="stylesheet" href="@Url.Content("~/Content/bootstrap/css/bootstrap.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Content/Site.css")" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <style>
        body {
            min-height: 100vh;
            padding-top: 74px;
            background: #f6f7fb;
            color: #22303c;
        }
        .navbar-brand {
            font-weight: 700;
            letter-spacing: 0.04em;
        }
        .body-content {
            padding: 24px 0 48px;
        }
        .page-header {
            margin-bottom: 1.75rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid rgba(33,37,41,.08);
        }
        .footer-brand {
            opacity: 0.7;
        }
        .card {
            border-radius: 1rem;
        }
        .btn-outline-primary:hover,
        .btn-outline-success:hover,
        .btn-outline-warning:hover,
        .btn-outline-info:hover {
            transform: translateY(-1px);
            transition: transform 0.2s ease;
        }
        .avatar {
            min-width: 48px;
        }
        .alert-dismissible .btn-close {
            top: 1rem;
            right: 1rem;
        }
        /* Mini-cart Drawer Styles */
        .mini-cart-drawer {
            position: fixed;
            top: 0;
            right: -385px;
            width: 385px;
            height: 100vh;
            background: #ffffff;
            box-shadow: -5px 0 30px rgba(15, 23, 42, 0.15);
            z-index: 1060;
            transition: right 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
        }
        .mini-cart-drawer.open {
            right: 0;
        }
        .mini-cart-backdrop {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(15, 23, 42, 0.4);
            backdrop-filter: blur(4px);
            z-index: 1050;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }
        .mini-cart-backdrop.show {
            opacity: 1;
            visibility: visible;
        }
        .mini-cart-header {
            padding: 1.25rem;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .mini-cart-body {
            flex-grow: 1;
            overflow-y: auto;
            padding: 1.25rem;
        }
        .mini-cart-item {
            display: flex;
            gap: 0.75rem;
            padding-bottom: 1rem;
            margin-bottom: 1rem;
            border-bottom: 1px solid #f1f5f9;
            align-items: center;
        }
        .hover-bg-light:hover {
            background-color: rgba(255, 255, 255, 0.15);
        }
    </style>
</head>
<body>
    @{
        var userRole = Session["UserRole"] as string;
        var isStaffOrAdmin = userRole == "ADMIN" || userRole == "STAFF";
        var isLoggedIn = Session["UserId"] != null;
    }
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top shadow-sm">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <i class="bi bi-lightning-charge-fill text-warning me-2"></i>
                <span>HUIT Shop</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Chuyển đổi điều hướng">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Product">Sản phẩm</a></li>
                    @if (isLoggedIn && isStaffOrAdmin)
                    {
                        <li class="nav-item"><a class="nav-link" href="/Inventory">Kho hàng</a></li>
                        <li class="nav-item"><a class="nav-link" href="/User">Người dùng</a></li>
                    }
                    <li class="nav-item"><a class="nav-link" href="/Review">Đánh giá</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Warranty">Bảo hành</a></li>
                </ul>
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-lg-center">
                    <li class="nav-item me-lg-3"><a class="nav-link" href="/Home/About">Về chúng tôi</a></li>
                    
                    <!-- Shopping Cart Icon with Count Badge -->
                    <li class="nav-item me-lg-2 position-relative" style="margin-right: 0.5rem;">
                        <a class="nav-link d-flex align-items-center p-2 rounded-circle hover-bg-light" href="javascript:void(0)" onclick="toggleMiniCart()" id="navCartLink" title="Giỏ hàng nhanh" style="position: relative;">
                            <i class="bi bi-cart3 fs-5 text-white"></i>
                            <span class="position-absolute translate-middle badge rounded-pill bg-danger d-none" id="navCartBadge" style="top: 8px; left: 28px; font-size: 0.65rem; padding: 0.25em 0.5em;">0</span>
                        </a>
                    </li>

                    @if (isLoggedIn)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="bg-primary-subtle text-primary rounded-circle d-inline-flex align-items-center justify-content-center me-2" style="width: 28px; height: 28px; background-color: rgba(59, 130, 246, 0.1);">
                                    <i class="bi bi-person" style="font-size: 0.95rem; color: #3b82f6;"></i>
                                </div>
                                <span class="fw-semibold">Chào, @Session["UserName"]</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-2" aria-labelledby="userDropdown" style="border-radius: 0.75rem;">
                                <li><a class="dropdown-item py-2 px-3 small" href="@Url.Action("Profile", "User")"><i class="bi bi-person me-2"></i>Trang cá nhân</a></li>
                                @if (isStaffOrAdmin)
                                {
                                    <li><a class="dropdown-item py-2 px-3 small" href="@Url.Action("Dashboard", "Inventory")"><i class="bi bi-speedometer2 me-2"></i>Quản trị kho</a></li>
                                    <li><a class="dropdown-item py-2 px-3 small" href="@Url.Action("Index", "User")"><i class="bi bi-people me-2"></i>Quản lý User</a></li>
                                }
                                <li><hr class="dropdown-divider opacity-10"></li>
                                <li>
                                    @using (Html.BeginForm("Logout", "Auth", FormMethod.Post, new { id = "logoutForm", @class = "d-none" }))
                                    {
                                        @Html.AntiForgeryToken()
                                    }
                                    <a class="dropdown-item py-2 px-3 small text-danger" href="javascript:document.getElementById('logoutForm').submit()"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link me-lg-2" href="@Url.Action("Login", "Auth")">Đăng nhập</a></li>
                        <li class="nav-item"><a class="btn btn-primary btn-sm px-3 rounded-pill text-white fw-semibold" href="@Url.Action("Register", "Auth")" style="background-color: #3b82f6; border-color: #3b82f6;">Đăng ký</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    <main class="container body-content">
        @RenderBody()
        <hr class="my-5" />
        <footer class="pb-4 text-muted small d-flex flex-column flex-md-row justify-content-between align-items-center">
            <div>&copy; @DateTime.Now.Year ECommerce HUIT</div>
            <div class="footer-brand">Thiết kế thân thiện cho quản trị và người dùng.</div>
        </footer>
    </main>

    <!-- Sliding Mini-Cart Drawer -->
    <div id="miniCartDrawer" class="mini-cart-drawer">
        <div class="mini-cart-header">
            <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-cart3 me-2 text-primary"></i>Giỏ hàng nhanh</h5>
            <button type="button" class="btn-close" onclick="toggleMiniCart()"></button>
        </div>
        <div class="mini-cart-body" id="miniCartBody">
            <div class="text-center py-5 text-muted">
                <div class="spinner-border spinner-border-sm text-primary mb-2" role="status"></div>
                <div>Đang tải giỏ hàng nhanh...</div>
            </div>
        </div>
        <div class="mini-cart-footer border-top p-3 bg-light" id="miniCartFooter" style="display: none;">
            <div class="d-flex justify-content-between mb-3 fw-bold text-dark">
                <span class="text-secondary small">Tổng tiền tạm tính:</span>
                <span class="text-danger font-monospace fs-5" id="miniCartTotalText">0đ</span>
            </div>
            <div class="d-grid gap-2">
                <a href="/Cart" class="btn btn-outline-primary fw-semibold py-2" style="border-radius: 0.5rem; font-size: 0.9rem;">Xem giỏ hàng chi tiết</a>
                <a href="/Cart/Checkout" class="btn btn-primary fw-semibold py-2" style="border-radius: 0.5rem; font-size: 0.9rem;">Tiến hành thanh toán</a>
            </div>
        </div>
    </div>
    <div id="miniCartBackdrop" class="mini-cart-backdrop" onclick="toggleMiniCart()"></div>

    <script src="@Url.Content("~/Content/bootstrap/js/bootstrap.bundle.min.js")"></script>

    <script>
        // Toggle Mini-Cart Drawer
        function toggleMiniCart() {
            const drawer = document.getElementById('miniCartDrawer');
            const backdrop = document.getElementById('miniCartBackdrop');
            
            if (drawer.classList.contains('open')) {
                drawer.classList.remove('open');
                backdrop.classList.remove('show');
            } else {
                drawer.classList.add('open');
                backdrop.classList.add('show');
                loadMiniCartData();
            }
        }

        // Fetch and render Mini-Cart items
        function loadMiniCartData() {
            const body = document.getElementById('miniCartBody');
            const footer = document.getElementById('miniCartFooter');
            
            body.innerHTML = `
                <div class="text-center py-5 text-muted">
                    <div class="spinner-border spinner-border-sm text-primary mb-2" role="status"></div>
                    <div>Đang tải giỏ hàng...</div>
                </div>
            `;
            
            fetch('/Cart/GetMiniCartJson')
                .then(response => response.json())
                .then(res => {
                    if (res.success && res.cart.items.length > 0) {
                        body.innerHTML = '';
                        res.cart.items.forEach(item => {
                            const formattedPrice = new Intl.NumberFormat('vi-VN').format(item.price) + 'đ';
                            const itemHtml = `
                                <div class="mini-cart-item">
                                    <img src="${item.img || 'https://via.placeholder.com/60x60?text=No+Img'}" class="rounded border" style="width: 50px; height: 50px; object-fit: cover;" alt="" />
                                    <div class="flex-grow-1" style="min-width: 0;">
                                        <div class="small fw-bold text-dark text-truncate mb-0" style="max-width: 170px;">${item.name}</div>
                                        <div class="text-muted small" style="font-size: 0.75rem;">SL: ${item.quantity}</div>
                                        <div class="text-danger fw-bold small mt-0.5">${formattedPrice}</div>
                                    </div>
                                    <button type="button" class="btn btn-link text-danger p-0 align-self-start ms-auto" onclick="removeMiniCartItem(${item.id})">
                                        <i class="bi bi-x-lg" style="font-size: 0.85rem;"></i>
                                    </button>
                                </div>
                            `;
                            body.innerHTML += itemHtml;
                        });
                        
                        document.getElementById('miniCartTotalText').innerText = new Intl.NumberFormat('vi-VN').format(res.cart.total) + 'đ';
                        footer.style.display = 'block';
                        
                        // Update nav badge
                        updateNavCartBadge(res.cart.cartCount);
                    } else {
                        body.innerHTML = `
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-cart-x fs-1 mb-2 text-secondary"></i>
                                <div class="small fw-bold text-secondary">Giỏ hàng của bạn trống!</div>
                                <a href="/Product" class="btn btn-primary btn-sm mt-3 px-4 rounded-pill" onclick="toggleMiniCart()">Mua sắm ngay</a>
                            </div>
                        `;
                        footer.style.display = 'none';
                        updateNavCartBadge(0);
                    }
                })
                .catch(() => {
                    body.innerHTML = `
                        <div class="text-center py-5 text-secondary small">
                            <i class="bi bi-exclamation-triangle-fill fs-3 mb-2 text-warning"></i>
                            <div>Đăng nhập để sử dụng giỏ hàng nhanh.</div>
                            <a href="/Auth/Login" class="btn btn-primary btn-sm mt-3 px-4 rounded-pill">Đăng nhập ngay</a>
                        </div>
                    `;
                    footer.style.display = 'none';
                    updateNavCartBadge(0);
                });
        }

        // Remove item from Mini-Cart
        function removeMiniCartItem(itemId) {
            fetch('/Cart/RemoveItem', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `cartItemId=${itemId}`
            })
            .then(response => response.json())
            .then(res => {
                if (res.success) {
                    loadMiniCartData();
                    // If currently on Cart Index page, reload it to synchronize values!
                    if (window.location.pathname.toLowerCase() === '/cart') {
                        window.location.reload();
                    }
                }
            });
        }

        // Helper to update the nav count badge
        function updateNavCartBadge(count) {
            const badge = document.getElementById('navCartBadge');
            if (badge) {
                badge.innerText = count;
                if (count > 0) {
                    badge.classList.remove('d-none');
                } else {
                    badge.classList.add('d-none');
                }
            }
        }

        // Global DOM loaded event to fetch quantity badge on page navigation
        document.addEventListener('DOMContentLoaded', function() {
            fetch('/Cart/GetMiniCartJson')
                .then(response => response.json())
                .then(res => {
                    if (res.success) {
                        updateNavCartBadge(res.cart.cartCount);
                    }
                })
                .catch(() => {});
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>

