@model IEnumerable<HuitShopDB.Models.DTOs.Product.ProductListDto>

@{
    ViewBag.Title = "Danh mục Sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var categories = ViewBag.Categories as List<HuitShopDB.Models.DTOs.Product.CategoryDto> ?? new List<HuitShopDB.Models.DTOs.Product.CategoryDto>();
    var brands = ViewBag.Brands as List<HuitShopDB.Models.DTOs.Product.BrandDto> ?? new List<HuitShopDB.Models.DTOs.Product.BrandDto>();
    var query = ViewBag.QueryParams as HuitShopDB.Models.DTOs.Product.ProductQueryParams ?? new HuitShopDB.Models.DTOs.Product.ProductQueryParams();

    // Pagination variables
    int totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    int totalCount = ViewBag.TotalCount != null ? (int)ViewBag.TotalCount : 0;
    int currentPage = query.Page > 0 ? query.Page : 1;
}

<style>
    .catalog-sidebar {
        background: #ffffff;
        border-radius: 1.25rem;
    }
    .filter-section-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: #1e293b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
    }
    .category-link {
        color: #475569;
        font-weight: 500;
        transition: all 0.2s ease;
        text-decoration: none;
        display: flex;
        align-items: center;
        padding: 0.4rem 0;
    }
    .category-link:hover, .category-link.active {
        color: #3b82f6;
        transform: translateX(4px);
    }
    .brand-checkbox {
        cursor: pointer;
        padding: 0.25rem 0;
    }
    .wishlist-heart {
        position: absolute;
        top: 0.75rem;
        right: 0.75rem;
        z-index: 10;
        background: #ffffff;
        color: #94a3b8;
        border: none;
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        transition: all 0.2s ease;
        cursor: pointer;
    }
    .wishlist-heart:hover {
        transform: scale(1.1);
        color: #ef4444;
    }
    .wishlist-heart.active {
        color: #ef4444;
        background: #fef2f2;
    }
    .search-suggestions {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        z-index: 100;
        background: #ffffff;
        border-radius: 0.75rem;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        border: 1px solid #e2e8f0;
        display: none;
        overflow: hidden;
    }
    .suggestion-item {
        padding: 0.75rem 1rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        cursor: pointer;
        transition: background 0.2s ease;
        text-decoration: none;
        color: #334155;
    }
    .suggestion-item:hover {
        background: #f8fafc;
        color: #3b82f6;
    }
</style>

<div class="container py-4">
    <!-- Header Banner -->
    <div class="bg-light p-4 p-md-5 mb-4 shadow-sm border-0 d-flex flex-wrap align-items-center justify-content-between position-relative overflow-hidden" style="border-radius: 1.5rem; background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);">
        <div class="position-relative" style="z-index: 2;">
            <span class="badge bg-primary rounded-pill px-3 py-2 small fw-semibold mb-2">HUIT CATALOG</span>
            <h1 class="fw-bold mb-1" style="color: #0f172a;">Khám Phá Sản Phẩm</h1>
            <p class="text-muted mb-0">Tìm kiếm sản phẩm yêu thích và trải nghiệm mua sắm thông minh</p>
        </div>
        <div class="d-none d-lg-block" style="opacity: 0.15; position: absolute; right: 40px; top: -10px;">
            <i class="bi bi-bag-check" style="font-size: 10rem; color: #3b82f6;"></i>
        </div>
    </div>

    <div class="row">
        <!-- Sidebar Filters -->
        <div class="col-lg-3 mb-4">
            <form id="filterForm" method="get" action="@Url.Action("Index", "Product")">
                <div class="catalog-sidebar shadow-sm p-4 border border-light-subtle">
                    <!-- Advanced Instant Search Input -->
                    <div class="mb-4 position-relative">
                        <label class="form-label text-secondary small fw-semibold">Tìm kiếm</label>
                        <div class="input-group">
                            <input type="text" id="searchInput" name="search" value="@query.Search" class="form-control bg-light border-0 py-2 px-3" style="border-radius: 0.75rem 0 0 0.75rem; height: 44px;" placeholder="Tìm sản phẩm..." autocomplete="off" />
                            <button type="submit" class="btn btn-primary px-3" style="border-radius: 0 0.75rem 0.75rem 0;"><i class="bi bi-search"></i></button>
                        </div>
                        <!-- Suggestion Container -->
                        <div id="searchSuggestions" class="search-suggestions"></div>
                    </div>

                    <hr class="my-4 opacity-10" />

                    <!-- Multi-level Categories -->
                    <div class="mb-4">
                        <div class="filter-section-title">
                            <i class="bi bi-grid-fill text-primary me-2"></i> Danh mục
                        </div>
                        <input type="hidden" name="categoryId" id="categoryIdInput" value="@query.CategoryId" />
                        <div class="d-flex flex-column gap-1">
                            <a href="#" class="category-link @(query.CategoryId == null ? "active" : "")" onclick="setCategory(null)">
                                <i class="bi bi-chevron-right small me-1"></i> Tất cả sản phẩm
                            </a>
                            @foreach (var parent in categories)
                            {
                                <a href="#" class="category-link fw-semibold text-dark mt-1 @(query.CategoryId == parent.Id ? "active text-primary" : "")" onclick="setCategory(@parent.Id)">
                                    <i class="bi bi-arrow-right-short me-1"></i> @parent.Name
                                </a>
                                if (parent.Children != null && parent.Children.Any())
                                {
                                    <div class="ps-3 d-flex flex-column border-start ms-2 py-1 gap-1" style="border-color: #cbd5e1 !important;">
                                        @foreach (var child in parent.Children)
                                        {
                                            <a href="#" class="category-link small @(query.CategoryId == child.Id ? "active text-primary" : "")" onclick="setCategory(@child.Id)">
                                                @child.Name
                                            </a>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <hr class="my-4 opacity-10" />

                    <!-- Brands Filter -->
                    <div class="mb-4">
                        <div class="filter-section-title">
                            <i class="bi bi-tag-fill text-primary me-2"></i> Thương hiệu
                        </div>
                        <input type="hidden" name="brandId" id="brandIdInput" value="@query.BrandId" />
                        <div style="max-height: 200px; overflow-y: auto;" class="pe-1">
                            @foreach (var brand in brands)
                            {
                                <div class="form-check brand-checkbox mb-2">
                                    <input class="form-check-input" type="radio" name="brandRadio" id="brand_@brand.Id" value="@brand.Id" @(query.BrandId == brand.Id ? "checked" : "") onchange="setBrand(@brand.Id)" />
                                    <label class="form-check-label text-secondary small fw-medium" for="brand_@brand.Id">
                                        @brand.Name
                                    </label>
                                </div>
                            }
                        </div>
                    </div>

                    <hr class="my-4 opacity-10" />

                    <!-- Price Filter -->
                    <div class="mb-4">
                        <div class="filter-section-title">
                            <i class="bi bi-cash-stack text-primary me-2"></i> Khoảng giá
                        </div>
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="text-secondary small">Từ (đ)</label>
                                <input type="number" name="minPrice" value="@(query.MinPrice.HasValue ? query.MinPrice.Value.ToString("0") : "")" class="form-control form-control-sm bg-light border-0 py-2" placeholder="Tối thiểu" style="border-radius: 0.5rem;" />
                            </div>
                            <div class="col-6">
                                <label class="text-secondary small">Đến (đ)</label>
                                <input type="number" name="maxPrice" value="@(query.MaxPrice.HasValue ? query.MaxPrice.Value.ToString("0") : "")" class="form-control form-control-sm bg-light border-0 py-2" placeholder="Tối đa" style="border-radius: 0.5rem;" />
                            </div>
                        </div>
                    </div>

                    <hr class="my-4 opacity-10" />

                    <!-- Stock switch -->
                    <div class="mb-4 form-check form-switch d-flex align-items-center justify-content-between p-0">
                        <label class="form-check-label text-secondary small fw-semibold" for="inStockOnly">Chỉ hiện sản phẩm còn hàng</label>
                        <input class="form-check-input" type="checkbox" name="inStockOnly" id="inStockOnly" value="true" @(query.InStockOnly ? "checked" : "") style="cursor: pointer; width: 42px; height: 21px;" />
                    </div>

                    <!-- Hidden Sort Option -->
                    <input type="hidden" name="sortBy" id="sortByInput" value="@query.SortBy" />
                    <input type="hidden" name="page" id="pageInput" value="@query.Page" />

                    <!-- Buttons -->
                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary fw-semibold" style="border-radius: 0.75rem; height: 44px;">
                            <i class="bi bi-funnel me-1"></i> Áp dụng bộ lọc
                        </button>
                        <a href="@Url.Action("Index", "Product")" class="btn btn-outline-secondary fw-semibold" style="border-radius: 0.75rem; height: 44px;">
                            Xóa bộ lọc
                        </a>
                    </div>
                </div>
            </form>
        </div>

        <!-- Central Product Grid Area -->
        <div class="col-lg-9">
            <!-- Filter Toolbar -->
            <div class="card border-0 shadow-sm p-3 mb-4 d-flex flex-wrap align-items-center justify-content-between gap-3" style="border-radius: 1rem; background: #ffffff;">
                <div class="text-muted small">
                    Tìm thấy <span class="fw-bold text-dark">@(Model != null ? Model.Count() : 0)</span> sản phẩm
                </div>
                <div class="d-flex align-items-center gap-2">
                    <label class="text-secondary small fw-medium text-nowrap mb-0"><i class="bi bi-sort-down me-1"></i> Sắp xếp:</label>
                    <select id="sortSelect" class="form-select form-select-sm bg-light border-0 py-2" style="border-radius: 0.5rem; width: 180px; height: 38px;" onchange="updateSorting(this.value)">
                        <option value="newest" @(query.SortBy == "newest" ? "selected" : "")>Mới nhất</option>
                        <option value="price_asc" @(query.SortBy == "price_asc" ? "selected" : "")>Giá: Thấp đến Cao</option>
                        <option value="price_desc" @(query.SortBy == "price_desc" ? "selected" : "")>Giá: Cao đến Thấp</option>
                        <option value="name" @(query.SortBy == "name" ? "selected" : "")>Tên sản phẩm A-Z</option>
                    </select>
                </div>
            </div>

            <!-- Product Grid -->
            @if (Model != null && Model.Any())
            {
                <div class="row g-3">
                    @foreach (var item in Model)
                    {
                        string imgUrl = !string.IsNullOrEmpty(item.ThumbnailUrl) ? item.ThumbnailUrl : "https://via.placeholder.com/300x300?text=HUIT+Shop";
                        decimal price = item.PriceFrom;
                        
                        <div class="col-6 col-md-4 col-lg-3" style="margin-bottom: 1rem;">
                            <a href="@Url.Action("Detail", "Product", new { id = item.Id })" class="cps-product-card position-relative">
                                <!-- Wishlist Heart Button -->
                                <button type="button" class="wishlist-heart position-absolute" data-id="@item.Id" onclick="event.preventDefault(); toggleWishlist(this, @item.Id)" title="Yêu thích" style="top: 10px; right: 10px; z-index: 2; width: 30px; height: 30px;">
                                    <i class="bi bi-heart-fill" style="font-size: 0.9rem;"></i>
                                </button>
                                
                                <img src="@imgUrl" class="cps-product-img" alt="@item.Name">
                                <div class="cps-product-name">@item.Name</div>
                                
                                <div class="d-flex align-items-center gap-1 mb-1">
                                    <div class="text-warning small" style="font-size: 0.75rem;">
                                        <i class="bi bi-star-fill"></i>
                                    </div>
                                    <span class="small fw-semibold text-dark" style="font-size: 0.75rem;">@(item.RatingAverage > 0 ? item.RatingAverage.ToString("F1") : "5.0")</span>
                                    <span class="text-muted small" style="font-size: 0.75rem;">(@(item.ReviewCount) đánh giá)</span>
                                </div>

                                <div class="cps-product-price">@(price > 0 ? price.ToString("N0") + "đ" : "Liên hệ")</div>
                                @if (item.PriceTo.HasValue && item.PriceTo > item.PriceFrom)
                                {
                                    <div class="cps-product-old-price">@item.PriceTo.Value.ToString("N0")đ</div>
                                }
                                <div class="cps-product-promo">
                                    <i class="bi bi-gift"></i> Khuyến mãi hấp dẫn
                                </div>
                            </a>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center mt-4 pt-2 border-top">
                    <div class="text-muted small mb-2 mb-sm-0">
                        <i class="bi bi-grid me-1"></i>
                        Hiển thị <strong>@Model.Count()</strong> / <strong>@totalCount</strong> sản phẩm
                        &nbsp;&bull;&nbsp; Trang <strong>@currentPage</strong> / <strong>@totalPages</strong>
                    </div>
                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-sm mb-0" style="gap:4px;">
                            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                                <a class="page-link rounded" href="#" onclick="changePage(1)" title="Trang đầu"><i class="bi bi-chevron-double-left"></i></a>
                            </li>
                            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                                <a class="page-link rounded" href="#" onclick="changePage(@(currentPage - 1))"><i class="bi bi-chevron-left"></i></a>
                            </li>
                            @for (int p = Math.Max(1, currentPage - 2); p <= Math.Min(totalPages, currentPage + 2); p++)
                            {
                                if (p == currentPage)
                                {
                                    <li class="page-item active"><span class="page-link rounded fw-bold" style="background:#3b82f6;border-color:#3b82f6;">@p</span></li>
                                }
                                else
                                {
                                    <li class="page-item"><a class="page-link rounded" href="#" onclick="changePage(@p)">@p</a></li>
                                }
                            }
                            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                                <a class="page-link rounded" href="#" onclick="changePage(@(currentPage + 1))"><i class="bi bi-chevron-right"></i></a>
                            </li>
                            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                                <a class="page-link rounded" href="#" onclick="changePage(@totalPages)" title="Trang cuối"><i class="bi bi-chevron-double-right"></i></a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
            else
            {
                <div class="text-center py-5 bg-white border border-light-subtle rounded-4 shadow-sm">
                    <div class="d-inline-flex align-items-center justify-content-center bg-light text-muted rounded-circle mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-search" style="font-size: 2.5rem;"></i>
                    </div>
                    <h4 class="fw-bold mb-1">Không tìm thấy sản phẩm nào</h4>
                    <p class="text-muted small">Hãy thử điều chỉnh bộ lọc hoặc từ khóa tìm kiếm của bạn.</p>
                    <a href="@Url.Action("Index", "Product")" class="btn btn-primary rounded-pill px-4 mt-2">
                        Xóa tất cả bộ lọc
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<script>
    // Search Autocomplete Suggestion Logic
    const searchInput = document.getElementById('searchInput');
    const suggestionsBox = document.getElementById('searchSuggestions');
    let debounceTimer;

    searchInput.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        const term = this.value.trim();

        if (term.length < 2) {
            suggestionsBox.style.display = 'none';
            return;
        }

        debounceTimer = setTimeout(() => {
            fetch(`/Product/InstantSearch?term=${encodeURIComponent(term)}`)
                .then(response => response.json())
                .then(res => {
                    if (res.success && res.data.length > 0) {
                        suggestionsBox.innerHTML = '';
                        res.data.forEach(p => {
                            const formattedPrice = new Intl.NumberFormat('vi-VN').format(p.price) + 'đ';
                            const itemHtml = `
                                <a href="/Product/Detail/${p.id}" class="suggestion-item">
                                    <img src="${p.img || 'https://via.placeholder.com/50x50'}" alt="" class="rounded" style="width: 40px; height: 40px; object-fit: cover;" />
                                    <div class="flex-grow-1">
                                        <div class="small fw-semibold text-truncate" style="max-width: 200px;">${p.name}</div>
                                        <div class="text-danger small fw-bold">${formattedPrice}</div>
                                    </div>
                                </a>
                            `;
                            suggestionsBox.innerHTML += itemHtml;
                        });
                        suggestionsBox.style.display = 'block';
                    } else {
                        suggestionsBox.style.display = 'none';
                    }
                })
                .catch(() => {
                    suggestionsBox.style.display = 'none';
                });
        }, 300);
    });

    document.addEventListener('click', function(e) {
        if (e.target !== searchInput && e.target !== suggestionsBox) {
            suggestionsBox.style.display = 'none';
        }
    });

    // Filtering Helpers
    function setCategory(id) {
        document.getElementById('categoryIdInput').value = id ? id : '';
        document.getElementById('pageInput').value = 1;
        document.getElementById('filterForm').submit();
    }

    function setBrand(id) {
        document.getElementById('brandIdInput').value = id ? id : '';
        document.getElementById('pageInput').value = 1;
        document.getElementById('filterForm').submit();
    }

    function updateSorting(sortBy) {
        document.getElementById('sortByInput').value = sortBy;
        document.getElementById('pageInput').value = 1;
        document.getElementById('filterForm').submit();
    }

    function changePage(page) {
        document.getElementById('pageInput').value = page;
        document.getElementById('filterForm').submit();
    }

    // Client-side Wishlist implementation using LocalStorage
    const wishlistKey = 'huit_wishlist';

    function getWishlist() {
        return JSON.parse(localStorage.getItem(wishlistKey)) || [];
    }

    function saveWishlist(list) {
        localStorage.setItem(wishlistKey, JSON.stringify(list));
    }

    function initWishlistUI() {
        const list = getWishlist();
        document.querySelectorAll('.wishlist-heart').forEach(btn => {
            const id = parseInt(btn.getAttribute('data-id'));
            if (list.includes(id)) {
                btn.classList.add('active');
            }
        });
    }

    function toggleWishlist(btn, id) {
        let list = getWishlist();
        id = parseInt(id);

        if (list.includes(id)) {
            list = list.filter(item => item !== id);
            btn.classList.remove('active');
        } else {
            list.push(id);
            btn.classList.add('active');
            // Subtle pop animation
            btn.style.transform = 'scale(1.25)';
            setTimeout(() => btn.style.transform = '', 200);
        }
        saveWishlist(list);
    }

    // Initialize wishlist states on load
    document.addEventListener('DOMContentLoaded', initWishlistUI);
</script>
