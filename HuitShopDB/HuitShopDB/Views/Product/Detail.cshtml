@model HuitShopDB.Models.DTOs.Product.ProductDetailDto

@{
    ViewBag.Title = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .checked-icon {
        transition: opacity 0.2s ease;
    }
    input.btn-check:checked + label {
        border-color: #d70018 !important;
        background-color: #fef2f2 !important;
        color: #d70018 !important;
    }
    input.btn-check:checked + label .checked-icon {
        opacity: 1 !important;
        color: #d70018;
    }
    .quantity-control {
        display: flex;
        align-items: center;
        border: 1px solid #cbd5e1;
        border-radius: 0.5rem;
        overflow: hidden;
        width: 120px;
    }
    .quantity-btn {
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8fafc;
        border: none;
        color: #475569;
        cursor: pointer;
        transition: background 0.2s;
    }
    .quantity-btn:hover:not(:disabled) {
        background: #e2e8f0;
    }
    .quantity-input {
        width: 48px;
        height: 36px;
        border: none;
        border-left: 1px solid #cbd5e1;
        border-right: 1px solid #cbd5e1;
        text-align: center;
        font-weight: 600;
        color: #1e293b;
        font-size: 0.95rem;
    }
    .quantity-input:focus {
        outline: none;
    }
    .detail-wishlist-heart.active {
        background-color: #fef2f2 !important;
        border-color: #fca5a5 !important;
        color: #ef4444 !important;
    }
</style>

<div class="container py-4">
    <!-- Breadcrumbs -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="/Product">Sản phẩm</a></li>
            <li class="breadcrumb-item active text-dark fw-medium" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <!-- Detail Alert Message Placeholder -->
    <div id="detailAlertPlaceholder"></div>

    <div class="row g-4">
        <!-- Left Column: Product Images (col-6) -->
        <div class="col-lg-6">
            @{
                string firstImage = "";
                if (Model.Images != null && Model.Images.Count > 0)
                {
                    firstImage = Model.Images[0].ImageUrl;
                }
                else if (Model.Variants != null && Model.Variants.Count > 0 && !string.IsNullOrEmpty(Model.Variants[0].ThumbnailUrl))
                {
                    firstImage = Model.Variants[0].ThumbnailUrl;
                }
                
                // Fix relative paths missing leading slash
                if (!string.IsNullOrEmpty(firstImage) && !firstImage.StartsWith("http") && !firstImage.StartsWith("/") && !firstImage.StartsWith("~"))
                {
                    firstImage = "/" + firstImage;
                }
            }
            <div class="bg-light rounded-4 overflow-hidden border border-light-subtle shadow-sm p-4 text-center">
                <img id="mainProductImg" src="@(string.IsNullOrEmpty(firstImage) ? "https://via.placeholder.com/600x600?text=No+Image" : (firstImage.StartsWith("~") ? Url.Content(firstImage) : firstImage))" class="img-fluid rounded-3" alt="@Model.Name" style="max-height: 480px; object-fit: contain; transition: transform 0.3s ease;" />
            </div>
            
            <!-- Gallery Thumbnails -->
            @if (Model.Images != null && Model.Images.Count > 1)
            {
                <div class="d-flex gap-2 mt-3 overflow-x-auto pb-2">
                    @foreach (var img in Model.Images)
                    {
                        <img src="@img.ImageUrl" class="rounded border p-1 bg-white cursor-pointer hover-shadow" style="width: 70px; height: 70px; object-fit: cover;" onclick="swapMainImage(this.src)" />
                    }
                </div>
            }
        </div>

        <!-- Right Column: Product Config & Buy (col-6) -->
        <div class="col-lg-6">
            <span class="badge bg-secondary rounded-pill px-3 py-1.5 small mb-2">@Model.Brand.Name</span>
            <h1 class="fw-bold mb-2" style="color: #0f172a;">@Model.Name</h1>

            <!-- Ratings Overview -->
            @{
                var summary = ViewBag.ReviewSummary as HuitShopDB.Models.DTOs.Review.ProductReviewSummaryDto;
                double avgRating = summary != null ? summary.AverageRating : 5.0;
                int totalReviews = summary != null ? summary.TotalReviews : 0;
            }
            <div class="d-flex align-items-center gap-2 mb-4">
                <div class="text-warning small d-flex gap-0.5">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi @(i <= Math.Round(avgRating) ? "bi-star-fill" : "bi-star")"></i>
                    }
                </div>
                <span class="small fw-bold text-dark">@avgRating.ToString("F1")</span>
                <span class="text-secondary small">(@totalReviews đánh giá)</span>
            </div>

            <!-- Dynamic Price tag -->
            <div class="mb-4 p-3 bg-light rounded-3 d-inline-block">
                <span class="text-secondary small d-block">Giá bán:</span>
                <span id="detailPriceLabel" class="text-danger fw-bold fs-2 font-monospace">
                    @(Model.Variants != null && Model.Variants.Count > 0 ? Model.Variants[0].Price.ToString("N0") : "0")đ
                </span>
            </div>

            <hr class="my-4 opacity-10" />

            <!-- Variant Choice Selector -->
            <div class="mb-4">
                <label class="form-label fw-bold text-secondary small">Chọn Phiên bản / Biến thể</label>
                <div class="d-flex flex-column gap-2" id="variantSelector">
                    @if (Model.Variants != null && Model.Variants.Any())
                    {
                        int idx = 0;
                        foreach (var variant in Model.Variants)
                        {
                            <div class="form-check p-0 m-0">
                                <input class="btn-check variant-radio-btn" type="radio" name="variantRadio" id="var_@variant.Id" value="@variant.Id" data-price="@variant.Price.ToString("N0")đ" data-img="@variant.ThumbnailUrl" @(idx == 0 ? "checked" : "") onchange="updateVariantSelection(this)" />
                                <label class="btn btn-outline-secondary w-100 text-start py-2.5 px-3 d-flex justify-content-between align-items-center" for="var_@variant.Id" style="border-radius: 0.75rem;">
                                    <span>
                                        <i class="bi bi-check-circle-fill me-2 checked-icon" style="opacity: 0;"></i>
                                        <strong>@variant.VariantName</strong>
                                    </span>
                                    <span class="text-danger fw-bold font-monospace">@variant.Price.ToString("N0")đ</span>
                                </label>
                            </div>
                            idx++;
                        }
                    }
                    else
                    {
                        <div class="alert alert-warning small py-2">Sản phẩm này tạm thời chưa có phiên bản khả dụng.</div>
                    }
                </div>
            </div>

            <!-- Quantity Selection -->
            <div class="mb-4 d-flex align-items-center gap-3">
                <label class="form-label fw-bold text-secondary small mb-0">Số lượng</label>
                <div class="quantity-control">
                    <button type="button" class="quantity-btn" onclick="adjustDetailQty(-1)"><i class="bi bi-minus"></i></button>
                    <input type="text" class="quantity-input" id="detailQtyInput" value="1" readonly />
                    <button type="button" class="quantity-btn" onclick="adjustDetailQty(1)"><i class="bi bi-plus"></i></button>
                </div>
            </div>

            <!-- CTA Buttons -->
            <div class="d-flex gap-3 mt-4">
                <button type="button" class="btn btn-primary btn-lg flex-grow-1 py-3 fw-bold shadow-sm" style="border-radius: 0.75rem;" onclick="addToCartFromDetail()">
                    <i class="bi bi-cart-plus me-1"></i> THÊM VÀO GIỎ HÀNG
                </button>
                <button type="button" class="btn btn-outline-danger btn-lg p-3 d-flex align-items-center justify-content-center detail-wishlist-heart" id="detailWishlistBtn" onclick="toggleDetailWishlist()" style="border-radius: 0.75rem; width: 58px;" title="Yêu thích">
                    <i id="detailHeartIcon" class="bi bi-heart" style="font-size: 1.25rem;"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Bottom Tab Description -->
    <div class="row mt-5 pt-4">
        <div class="col-lg-8">
            <h4 class="fw-bold border-bottom pb-2 mb-4" style="color: #0f172a;">Thông tin chi tiết</h4>
            <div class="lh-lg text-secondary">
                @Html.Raw(Model.Description)
            </div>
        </div>
    </div>

    <!-- Review Section -->
    <div class="row mt-5 pt-4">
        <div class="col-lg-12">
            <h4 class="fw-bold border-bottom pb-2 mb-4" style="color: #0f172a;">Đánh giá & Nhận xét sản phẩm</h4>
            
            <div class="row g-4">
                <!-- Stats Breakdown -->
                <div class="col-md-4 text-center border-end">
                    <h1 class="display-3 fw-bold text-warning mb-1 font-monospace">@avgRating.ToString("0.0")</h1>
                    <div class="mb-2 text-warning fs-4 d-flex justify-content-center gap-1">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="bi @(i <= Math.Round(avgRating) ? "bi-star-fill" : "bi-star")"></i>
                        }
                    </div>
                    <p class="text-muted">Tổng số @totalReviews lượt đánh giá thực tế</p>
                </div>

                <!-- Submit new Review -->
                <div class="col-md-8 px-md-5">
                    <h5 class="fw-bold mb-3"><i class="bi bi-chat-left-dots text-primary me-2"></i>Gửi phản hồi của bạn</h5>
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success border-0 shadow-sm rounded-3">@TempData["SuccessMessage"]</div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger border-0 shadow-sm rounded-3">@TempData["ErrorMessage"]</div>
                    }
                    <form action="/Product/SubmitReview" method="post">
                        <input type="hidden" name="ProductId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label text-secondary small fw-semibold">Xếp hạng độ hài lòng</label>
                            <select name="Rating" class="form-select bg-light border-0 py-2 px-3" style="border-radius: 0.5rem; width: 140px;" required>
                                <option value="5">5 Sao (Rất tốt)</option>
                                <option value="4">4 Sao (Tốt)</option>
                                <option value="3">3 Sao (Bình thường)</option>
                                <option value="2">2 Sao (Chưa tốt)</option>
                                <option value="1">1 Sao (Kém)</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-secondary small fw-semibold">Tiêu đề đánh giá</label>
                            <input type="text" name="Title" class="form-control bg-light border-0 py-2 px-3" style="border-radius: 0.5rem;" placeholder="Mô tả ngắn nhận xét (ví dụ: Sản phẩm rất mượt mà)" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-secondary small fw-semibold">Chi tiết bình luận</label>
                            <textarea name="Content" class="form-control bg-light border-0 py-2 px-3" style="border-radius: 0.5rem;" rows="3" placeholder="Viết đánh giá chi tiết của bạn về hiệu năng, màu sắc, chế độ bảo hành..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary px-4 py-2 fw-semibold" style="border-radius: 0.5rem;">Gửi đánh giá</button>
                    </form>
                </div>
            </div>

            <!-- List recent Reviews -->
            <div class="mt-5">
                <h5 class="fw-bold mb-4">Nhận xét từ người mua hàng</h5>
                @if (summary != null && summary.LatestReviews.Any())
                {
                    foreach (var r in summary.LatestReviews)
                    {
                        <div class="card border-light-subtle shadow-sm bg-white mb-3" style="border-radius: 1rem;">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; font-weight: 700; font-size: 0.9rem;">
                                            @(r.UserName.Substring(0, 1).ToUpper())
                                        </div>
                                        <div>
                                            <span class="fw-bold text-dark d-block">@r.UserName</span>
                                            @if (r.IsVerifiedPurchase)
                                            {
                                                <span class="badge bg-success-subtle text-success py-1 px-2 font-semibold" style="font-size: 0.65rem;"><i class="bi bi-shield-check me-1"></i>Đã mua hàng</span>
                                            }
                                        </div>
                                    </div>
                                    <small class="text-muted">@r.CreatedAt.ToString("dd/MM/yyyy")</small>
                                </div>
                                <div class="text-warning mb-2 d-flex gap-0.5" style="font-size: 0.8rem;">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi @(i <= r.Rating ? "bi-star-fill" : "bi-star")"></i>
                                    }
                                </div>
                                <h6 class="fw-bold text-dark">@r.Title</h6>
                                <p class="mb-0 text-secondary" style="font-size: 0.9rem;">@r.Content</p>
                                
                                @if (r.AdminResponse != null)
                                {
                                    <div class="mt-4 p-3 bg-light rounded-3 border-start border-primary border-4 shadow-sm">
                                        <div class="d-flex align-items-center mb-1">
                                            <i class="bi bi-patch-check-fill text-primary me-2"></i>
                                            <span class="fw-bold text-primary small">@r.AdminResponse.AdminName (HUIT Shop) - Phản hồi từ quản trị viên</span>
                                        </div>
                                        <p class="mb-0 text-dark small">@r.AdminResponse.Content</p>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5 bg-light rounded-4 text-muted border border-light-subtle">
                        <i class="bi bi-chat-square-text fs-2 mb-2 text-secondary"></i>
                        <div>Chưa có đánh giá nào cho sản phẩm này. Hãy mua hàng và để lại đánh giá đầu tiên!</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    // Swap main image when clicking gallery thumbs
    function swapMainImage(src) {
        document.getElementById('mainProductImg').src = src;
    }

    // Update variant price / thumbnail
    function updateVariantSelection(radio) {
        const price = radio.getAttribute('data-price');
        let img = radio.getAttribute('data-img');
        
        document.getElementById('detailPriceLabel').innerText = price;
        if (img) {
            if (!img.startsWith('http') && !img.startsWith('/')) {
                img = '/' + img;
            }
            document.getElementById('mainProductImg').src = img;
        }
    }

    // Detail Quantity Adjustments
    function adjustDetailQty(change) {
        const input = document.getElementById('detailQtyInput');
        let val = parseInt(input.value) + change;
        if (val < 1) val = 1;
        input.value = val;
    }

    // AJAX: Add product to cart and open sliding drawer
    function addToCartFromDetail() {
        const selectedRadio = document.querySelector('.variant-radio-btn:checked');
        if (!selectedRadio) {
            showDetailAlert('Vui lòng chọn một phiên bản sản phẩm.', 'warning');
            return;
        }

        const variantId = selectedRadio.value;
        const qty = document.getElementById('detailQtyInput').value;

        fetch('/Cart/AddToCart', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `variantId=${variantId}&quantity=${qty}`
        })
        .then(response => response.json())
        .then(res => {
            if (res.success) {
                // Open dynamic mini-cart drawer to give feedback
                if (typeof toggleMiniCart === 'function') {
                    // Open drawer
                    const drawer = document.getElementById('miniCartDrawer');
                    const backdrop = document.getElementById('miniCartBackdrop');
                    if (drawer && !drawer.classList.contains('open')) {
                        drawer.classList.add('open');
                        backdrop.classList.add('show');
                    }
                    if (typeof loadMiniCartData === 'function') {
                        loadMiniCartData();
                    }
                }
                showDetailAlert('Đã thêm sản phẩm vào giỏ hàng thành công!', 'success');
            } else {
                if (res.message === 'unauthorized') {
                    showDetailAlert('Bạn cần đăng nhập để thêm sản phẩm vào giỏ hàng. <a href="/Auth/Login" class="alert-link">Đăng nhập ngay</a>', 'danger');
                } else {
                    showDetailAlert(res.message || 'Không thể thêm sản phẩm vào giỏ hàng.', 'danger');
                }
            }
        })
        .catch(err => {
            showDetailAlert('Có lỗi kết nối xảy ra. Vui lòng thử lại.', 'danger');
        });
    }

    function showDetailAlert(message, type = 'danger') {
        const container = document.getElementById('detailAlertPlaceholder');
        container.innerHTML = `
            <div class="alert alert-${type} alert-dismissible fade show border-0 shadow-sm rounded-3 py-3 mb-4" role="alert">
                <i class="bi ${type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill'} me-2"></i>
                <span class="small fw-semibold">${message}</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        `;
    }

    // Detail Wishlist LocalStorage Integration
    const wishlistKey = 'huit_wishlist';

    function getWishlist() {
        return JSON.parse(localStorage.getItem(wishlistKey)) || [];
    }

    function saveWishlist(list) {
        localStorage.setItem(wishlistKey, JSON.stringify(list));
    }

    function initDetailWishlistUI() {
        const list = getWishlist();
        const productId = parseInt('@Model.Id');
        const btn = document.getElementById('detailWishlistBtn');
        const icon = document.getElementById('detailHeartIcon');
        
        if (list.includes(productId)) {
            btn.classList.add('active');
            icon.className = 'bi bi-heart-fill';
        } else {
            btn.classList.remove('active');
            icon.className = 'bi bi-heart';
        }
    }

    function toggleDetailWishlist() {
        let list = getWishlist();
        const productId = parseInt('@Model.Id');
        const btn = document.getElementById('detailWishlistBtn');
        const icon = document.getElementById('detailHeartIcon');

        if (list.includes(productId)) {
            list = list.filter(id => id !== productId);
            btn.classList.remove('active');
            icon.className = 'bi bi-heart';
        } else {
            list.push(productId);
            btn.classList.add('active');
            icon.className = 'bi bi-heart-fill';
            
            // Heart pop animation
            btn.style.transform = 'scale(1.2)';
            setTimeout(() => btn.style.transform = '', 200);
        }
        saveWishlist(list);
    }

    document.addEventListener('DOMContentLoaded', initDetailWishlistUI);
</script>
